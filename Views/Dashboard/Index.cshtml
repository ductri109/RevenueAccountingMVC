@model RevenueAccountingMVC.ViewModels.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard Tổng quan";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="bg-[#f4f7f6] min-h-screen font-['Inter'] pb-10">
    
    <div class="bg-white px-8 py-5 border-b border-gray-200 flex flex-col md:flex-row justify-between items-start md:items-center">
        <div>
            <h1 class="text-[26px] font-extrabold text-slate-800 tracking-tight">Dashboard</h1>
            <p class="text-[13px] text-gray-500 mt-1">Tổng quan doanh thu bán hàng</p>
        </div>
        
        @{
            // --- LOGIC XÁC ĐỊNH NÚT ACTIVE ---
            var today = DateTime.Now.Date;
            var from = Model.FromDate;
            var to = Model.ToDate;

            // Tính mốc thời gian Tháng
            var monthStart = new DateTime(today.Year, today.Month, 1);
            var monthEnd = monthStart.AddMonths(1).AddDays(-1);

            // Tính mốc thời gian Quý
            int quarter = (today.Month - 1) / 3 + 1;
            var quarterStart = new DateTime(today.Year, (quarter - 1) * 3 + 1, 1);
            var quarterEnd = quarterStart.AddMonths(3).AddDays(-1);

            // Tính mốc thời gian Năm
            var yearStart = new DateTime(today.Year, 1, 1);
            var yearEnd = new DateTime(today.Year, 12, 31);

            // Kiểm tra xem FromDate/ToDate hiện tại đang khớp với khoảng nào
            // (Chấp nhận ToDate có thể là ngày cuối cùng của kỳ HOẶC là ngày hôm nay)
            bool isMonth = from == monthStart && (to == monthEnd || to == today);
            bool isQuarter = from == quarterStart && (to == quarterEnd || to == today);
            bool isYear = from == yearStart && (to == yearEnd || to == today);

            // Khai báo sẵn các class CSS cho trạng thái Bật / Tắt
            string activeClass = "px-5 py-1.5 text-[13px] font-semibold bg-[#0f766e] text-white shadow-sm rounded-md transition-all hover:bg-[#115e59]";
            string inactiveClass = "px-5 py-1.5 text-[13px] font-medium text-gray-600 hover:text-gray-900 rounded-md transition-all hover:bg-gray-200";
        }

        <div class="mt-4 md:mt-0 flex bg-gray-100 p-1 rounded-lg">
            <button type="button" onclick="applyQuickFilter('month')" class="@(isMonth ? activeClass : inactiveClass)">Tháng</button>
            <button type="button" onclick="applyQuickFilter('quarter')" class="@(isQuarter ? activeClass : inactiveClass)">Quý</button>
            <button type="button" onclick="applyQuickFilter('year')" class="@(isYear ? activeClass : inactiveClass)">Năm</button>
        </div>
    </div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 mt-6">
        <div class="flex flex-col lg:flex-row gap-6">
            
            <div class="w-full lg:w-3/4 space-y-6">
                
                @if (!Model.HasData && ViewData.ModelState.IsValid)
                {
                    <div class="bg-white rounded-xl shadow-sm p-16 border border-gray-100 flex flex-col items-center justify-center text-center h-[500px]">
                        <i class="fas fa-inbox text-5xl text-gray-300 mb-4"></i>
                        <h3 class="text-[18px] font-bold text-gray-900 mb-1">Không có dữ liệu</h3>
                        <p class="text-[14px] text-gray-500">Chưa có doanh thu nào được ghi nhận trong thời gian này.</p>
                    </div>
                }
                else if (Model.HasData)
                {
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm flex justify-between items-center">
                            <div>
                                <p class="text-[13px] font-medium text-gray-500 mb-1">Doanh thu bán hàng</p>
                                <h3 class="text-2xl font-bold text-gray-900">@Model.TotalRevenue.ToString("N0") <span class="text-sm font-normal text-gray-500">VNĐ</span></h3>
                                <p class="text-[12px] font-semibold text-green-500 mt-2 flex items-center gap-1"><i class="fas fa-arrow-up"></i> Tăng trưởng ổn định</p>
                            </div>
                            <div class="w-12 h-12 rounded-xl bg-[#effcf6] text-[#0f766e] flex items-center justify-center text-xl">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm flex justify-between items-center">
                            <div>
                                <p class="text-[13px] font-medium text-gray-500 mb-1">Số khách hàng</p>
                                <h3 class="text-2xl font-bold text-gray-900">@Model.TotalCustomers</h3>
                                <p class="text-[12px] font-semibold text-green-500 mt-2 flex items-center gap-1"><i class="fas fa-arrow-up"></i> Khách hàng phát sinh</p>
                            </div>
                            <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center text-lg">
                                <i class="fas fa-user-friends"></i>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm flex justify-between items-center">
                            <div>
                                <p class="text-[13px] font-medium text-gray-500 mb-1">Số hàng hóa/dịch vụ</p>
                                <h3 class="text-2xl font-bold text-gray-900">@Model.TotalProducts</h3>
                                <p class="text-[12px] font-semibold text-green-500 mt-2 flex items-center gap-1"><i class="fas fa-arrow-up"></i> Mặt hàng bán ra</p>
                            </div>
                            <div class="w-12 h-12 rounded-xl bg-purple-50 text-purple-600 flex items-center justify-center text-lg">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                            <h3 class="font-bold text-[15px] text-gray-900 mb-6">Top 10 khách hàng có doanh thu cao nhất</h3>
                            <div class="h-[280px] w-full">
                                <canvas id="customerChart"></canvas>
                            </div>
                        </div>

                        <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                            <div class="flex justify-between items-center mb-6">
                                <h3 class="font-bold text-[15px] text-gray-900">Top 10 hàng hóa có doanh thu cao nhất</h3>
                        <div class="flex bg-gray-100 p-1 rounded-md">
                            <button type="button" id="btnTabGoods" onclick="switchProductTab('goods')" class="px-3 py-1 text-[12px] font-semibold bg-white text-gray-800 shadow-sm rounded transition-all">Hàng hóa</button>
                            <button type="button" id="btnTabServices" onclick="switchProductTab('services')" class="px-3 py-1 text-[12px] font-medium text-gray-500 hover:text-gray-800 rounded transition-all">Dịch vụ</button>
                        </div>
                            </div>
                            <div class="h-[280px] w-full">
                                <canvas id="productChart"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
                        <h3 class="font-bold text-[15px] text-gray-900 mb-6">Doanh thu theo thời gian</h3>
                        <div class="h-[300px] w-full">
                            <canvas id="timeChart"></canvas>
                        </div>
                    </div>
                }
            </div>

            <div class="w-full lg:w-1/4">
                <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 sticky top-6">
                    <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-3">
                        <h3 class="font-bold text-gray-900 text-[15px] flex items-center gap-2">
                            <i class="fas fa-filter text-[#0f766e]"></i> Bộ lọc
                        </h3>
                        <a href="@Url.Action("Index", "Dashboard")" class="text-[13px] font-medium text-gray-500 hover:text-[#0f766e]">Đặt lại</a>
                    </div>
                    
                    <form asp-action="Index" method="get">
                        <div class="mb-5">
                            <label class="block text-[13px] font-medium text-gray-700 mb-2">Từ ngày</label>
                            <input type="date" name="fromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="w-full border border-gray-200 focus:border-[#0f766e] focus:ring-1 focus:ring-[#0f766e] rounded-lg px-3 py-2.5 text-[14px] outline-none transition-colors" />
                        </div>
                        
                        <div class="mb-5">
                            <label class="block text-[13px] font-medium text-gray-700 mb-2">Đến ngày</label>
                            <input type="date" name="toDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="w-full border border-gray-200 focus:border-[#0f766e] focus:ring-1 focus:ring-[#0f766e] rounded-lg px-3 py-2.5 text-[14px] outline-none transition-colors" />
                        </div>
                        
                        <div class="mb-5">
                            <label class="block text-[13px] font-medium text-gray-700 mb-2">Khách hàng</label>
                            <select name="customerId" class="w-full border border-gray-200 focus:border-[#0f766e] focus:ring-1 focus:ring-[#0f766e] rounded-lg px-3 py-2.5 text-[14px] outline-none transition-colors">
                                <option value="">-- Tất cả khách hàng --</option>
                                @if(ViewBag.Customers != null)
                                {
                                    foreach (var c in ViewBag.Customers)
                                    {
                                        if (Model.CustomerId == c.Id) { <option value="@c.Id" selected>@c.CustomerName</option> }
                                        else { <option value="@c.Id">@c.CustomerName</option> }
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-6">
                            <label class="block text-[13px] font-medium text-gray-700 mb-2">Tìm kiếm nhanh</label>
                            <div class="relative">
                                <i class="fas fa-search absolute left-3 top-3 text-gray-400 text-[13px]"></i>
                                <input type="text" id="txtQuickSearch" oninput="filterCharts()" placeholder="Tìm khách hàng, hàng hóa..." class="w-full border border-gray-200 focus:border-[#0f766e] focus:ring-1 focus:ring-[#0f766e] rounded-lg pl-8 pr-3 py-2 text-[14px] outline-none transition-colors" />
                            </div>
                        </div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="text-red-500 text-[12px] mb-4 bg-red-50 p-3 rounded-lg border border-red-100"></div>
                        }

                        <button type="submit" class="w-full bg-[#0f766e] hover:bg-[#115e59] text-white py-2.5 rounded-lg text-[14px] font-semibold transition-all shadow-md">
                            Áp dụng bộ lọc
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if(Model.HasData)
    {
        <script>
            // Lấy dữ liệu từ Model
            const customerData = @Html.Raw(JsonSerializer.Serialize(Model.TopCustomers));
            const goodsData = @Html.Raw(JsonSerializer.Serialize(Model.TopGoods));
            const servicesData = @Html.Raw(JsonSerializer.Serialize(Model.TopServices));
            const timeData = @Html.Raw(JsonSerializer.Serialize(Model.RevenueOverTime));

            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = '#64748b';
            const formatMoney = (value) => value.toLocaleString('vi-VN') + ' đ';

            // BIẾN LƯU TRỮ INSTANCE CỦA CHART
            let customerChart, productChart, timeChart;
            let currentTab = 'goods'; // Mặc định đang ở tab hàng hóa

            // 1. VẼ BIỂU ĐỒ KHÁCH HÀNG
            customerChart = new Chart(document.getElementById('customerChart'), {
                type: 'bar',
                data: {
                    labels: customerData.map(x => x.Label.length > 15 ? x.Label.substring(0, 15) + '...' : x.Label),
                    datasets: [{
                        data: customerData.map(x => x.Value),
                        backgroundColor: '#14b8a6', hoverBackgroundColor: '#0f766e', borderRadius: 4, barPercentage: 0.6
                    }]
                },
                options: {
                    indexAxis: 'y', responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => formatMoney(ctx.raw) } } },
                    scales: { x: { display: false }, y: { border: { display: false }, grid: { display: false } } }
                }
            });

            // 2. VẼ BIỂU ĐỒ hàng hóa/DỊCH VỤ
            productChart = new Chart(document.getElementById('productChart'), {
                type: 'bar',
                data: {
                    labels: goodsData.map(x => x.Label.length > 10 ? x.Label.substring(0, 10) + '...' : x.Label),
                    datasets: [{
                        data: goodsData.map(x => x.Value),
                        backgroundColor: '#0f766e', hoverBackgroundColor: '#115e59', borderRadius: { topLeft: 4, topRight: 4 }, barPercentage: 0.5
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => formatMoney(ctx.raw) } } },
                    scales: { y: { border: { display: false }, grid: { color: '#f1f5f9' }, ticks: { callback: (val) => val.toLocaleString('vi-VN') } }, x: { grid: { display: false } } }
                }
            });

            // 3. VẼ BIỂU ĐỒ THỜI GIAN (Giữ nguyên)
            timeChart = new Chart(document.getElementById('timeChart'), {
                type: 'line',
                data: {
                    labels: timeData.map(x => x.Label),
                    datasets: [{
                        label: 'Doanh thu', data: timeData.map(x => x.Value), borderColor: '#0f766e', backgroundColor: 'rgba(15, 118, 110, 0.1)', borderWidth: 2, fill: true, tension: 0.4, pointBackgroundColor: '#fff', pointBorderColor: '#0f766e', pointBorderWidth: 2, pointRadius: 3
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => formatMoney(ctx.raw) } } },
                    scales: { y: { border: { display: false }, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
                }
            });

            // ==========================================
            // HÀM CHUYỂN ĐỔI TAB hàng hóa / DỊCH VỤ
            // ==========================================
            function switchProductTab(tab) {
                currentTab = tab;
                const isGoods = tab === 'goods';
                
                // Cập nhật giao diện nút
                document.getElementById('btnTabGoods').className = isGoods ? 'px-3 py-1 text-[12px] font-semibold bg-white text-gray-800 shadow-sm rounded transition-all' : 'px-3 py-1 text-[12px] font-medium text-gray-500 hover:text-gray-800 rounded transition-all';
                document.getElementById('btnTabServices').className = !isGoods ? 'px-3 py-1 text-[12px] font-semibold bg-white text-gray-800 shadow-sm rounded transition-all' : 'px-3 py-1 text-[12px] font-medium text-gray-500 hover:text-gray-800 rounded transition-all';

                // Lọc lại dữ liệu (kết hợp ô tìm kiếm hiện tại nếu có)
                filterCharts();
            }

            // ==========================================
            // HÀM LỌC NHANH (TÌM KIẾM REAL-TIME)
            // ==========================================
            function filterCharts() {
                const keyword = document.getElementById('txtQuickSearch').value.toLowerCase();

                // 1. Lọc mảng Khách hàng
                const filteredCustomers = customerData.filter(x => x.Label.toLowerCase().includes(keyword));
                customerChart.data.labels = filteredCustomers.map(x => x.Label.length > 15 ? x.Label.substring(0, 15) + '...' : x.Label);
                customerChart.data.datasets[0].data = filteredCustomers.map(x => x.Value);
                customerChart.update();

                // 2. Lọc mảng hàng hóa / Dịch vụ dựa theo Tab đang mở
                const sourceData = currentTab === 'goods' ? goodsData : servicesData;
                const filteredProducts = sourceData.filter(x => x.Label.toLowerCase().includes(keyword));
                
                productChart.data.labels = filteredProducts.map(x => x.Label.length > 10 ? x.Label.substring(0, 10) + '...' : x.Label);
                productChart.data.datasets[0].data = filteredProducts.map(x => x.Value);
                productChart.update();
            }
            // Hàm xử lý lọc nhanh
            function applyQuickFilter(type) {
                const today = new Date();
                let fromDate, toDate;
                const year = today.getFullYear();
                const month = today.getMonth();

                if (type === 'month') {
                    // Từ ngày đầu tháng đến ngày cuối tháng
                    fromDate = new Date(year, month, 1);
                    toDate = new Date(year, month + 1, 0);
                } 
                else if (type === 'quarter') {
                    // Từ ngày đầu quý đến ngày cuối quý
                    const quarterStartMonth = Math.floor(month / 3) * 3;
                    fromDate = new Date(year, quarterStartMonth, 1);
                    toDate = new Date(year, quarterStartMonth + 3, 0);
                } 
                else if (type === 'year') {
                    // Từ 1/1 đến 31/12 của năm hiện tại
                    fromDate = new Date(year, 0, 1);
                    toDate = new Date(year, 11, 31);
                }

                // Hàm format ngày chuẩn yyyy-MM-dd cho thẻ input type="date"
                const formatDate = (date) => {
                    const d = date.getDate().toString().padStart(2, '0');
                    const m = (date.getMonth() + 1).toString().padStart(2, '0');
                    const y = date.getFullYear();
                    return `${y}-${m}-${d}`;
                };

                // Gán giá trị vào 2 ô Input ở cột bộ lọc bên phải
                document.querySelector('input[name="fromDate"]').value = formatDate(fromDate);
                document.querySelector('input[name="toDate"]').value = formatDate(toDate);
                
                // Tự động submit form lọc
                document.querySelector('form').submit();
            }
        </script>
    }
}