@model IEnumerable<RevenueAccountingMVC.Models.RevenueByCustomerReportLine>
@{
    Layout = null; 
    DateTime fromDate = ViewBag.FromDate;
    DateTime toDate = ViewBag.ToDate;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Báo Cáo Tổng Hợp Doanh Thu</title>
    <style>
        @@media print {
            @@page { size: A4 portrait; margin: 15mm; }
            body { -webkit-print-color-adjust: exact; }
        }
        body {
            font-family: 'Times New Roman', serif;
            font-size: 12pt;
            color: #000;
            line-height: 1.4;
            background: #fff;
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
        }
        .header-company { margin-bottom: 30px; }
        .header-company div { margin-bottom: 3px; }
        .font-bold { font-weight: bold; }
        .font-italic { font-style: italic; }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        
        .report-title {
            font-size: 16pt;
            font-weight: bold;
            text-align: center;
            margin-top: 20px;
            margin-bottom: 5px;
            text-transform: uppercase;
        }
        .report-subtitle {
            text-align: center;
            font-style: italic;
            margin-bottom: 20px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 40px;
        }
        th, td {
            border: 1px solid #000;
            padding: 8px 10px;
        }
        th {
            text-align: center;
            font-weight: bold;
            vertical-align: middle;
        }
        
        .signature-table {
            width: 100%;
            border: none;
            page-break-inside: avoid;
        }
        .signature-table td {
            border: none;
            text-align: center;
            vertical-align: top;
            width: 33.33%;
            padding: 0;
        }
    </style>
</head>
<body onload="window.print()">
    <!-- Header Thông tin công ty -->
    <div class="header-company">
        <div class="font-bold">Đơn vị: Công ty Cổ phần Phần mềm BRAVO</div>
        <div><span class="font-bold">Địa chỉ:</span> Tầng 7, Tòa Nhà Văn Phòng 311-313, Đường Trường Chinh, Phường Phương Liệt, Hà Nội.</div>
        <div><span class="font-bold">Mã số thuế:</span> 0800263590</div>
        <div><span class="font-bold">Điện thoại:</span> 0320895604</div>
    </div>

    <!-- Tiêu đề báo cáo -->
    <div class="report-title">BÁO CÁO TỔNG HỢP DOANH THU</div>
    <div class="report-subtitle">Từ ngày @fromDate.ToString("dd/MM/yyyy") đến ngày @toDate.ToString("dd/MM/yyyy")</div>

    <!-- Bảng số liệu -->
    <table>
        <thead>
            <tr>
                <th style="width: 12%;">Mã KH</th>
                <th style="width: 40%;">Tên khách hàng</th>
                <th style="width: 16%;">Doanh thu</th>
                <th style="width: 16%;">Giảm trừ</th>
                <th style="width: 16%;">Doanh thu thuần</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td class="text-center font-bold">@item.CustomerCode</td>
                    <td class="font-bold">@item.CustomerName.ToUpper()</td>
                    <td class="text-right">@item.TotalRevenue.ToString("N2")</td>
                    <td class="text-right">@Math.Abs(item.AdjustmentRevenue).ToString("N2")</td>
                    <td class="text-right">@item.NetRevenue.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Chữ ký -->
    <table class="signature-table">
        <tr>
            <td>
                <div class="font-bold">Người lập báo cáo</div>
                <div class="font-italic">(Ký và ghi rõ họ tên)</div>
            </td>
            <td>
                <div class="font-bold">Kế toán trưởng</div>
                <div class="font-italic">(Ký và ghi rõ họ tên)</div>
            </td>
            <td>
                <div>Ngày @DateTime.Now.Day tháng @DateTime.Now.Month năm @DateTime.Now.Year</div>
                <div class="font-bold">Giám đốc</div>
                <div class="font-italic">(Ký và ghi rõ họ tên)</div>
            </td>
        </tr>
    </table>
</body>
</html>