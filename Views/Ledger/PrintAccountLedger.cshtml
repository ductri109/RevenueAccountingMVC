@model RevenueAccountingMVC.ViewModels.ReportViewModel
@{
    Layout = null; // Bỏ qua layout chính
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Sổ Cái - @Model.AccountNumber</title>
    <style>
        @@media print {
            @@page { size: A4 portrait; margin: 15mm 15mm 20mm 15mm; }
            body { -webkit-print-color-adjust: exact; }
        }
        body {
            font-family: 'Times New Roman', serif;
            font-size: 11pt;
            color: #000;
            line-height: 1.3;
            background: #fff;
        }
        table { width: 100%; border-collapse: collapse; }
        .layout-table td { border: none; padding: 0; vertical-align: top; }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .font-bold { font-weight: bold; }
        .font-italic { font-style: italic; }
        
        .title { font-size: 16pt; font-weight: bold; text-align: center; margin-top: 15px; margin-bottom: 5px; }
        .data-table { margin-top: 15px; width: 100%; }
        .data-table th, .data-table td { border: 1px solid #000; padding: 5px; }
        .data-table th { text-align: center; vertical-align: middle; font-weight: normal; }
        
        .signature-table { margin-top: 20px; width: 100%; page-break-inside: avoid; }
        .signature-table td { border: none; text-align: center; vertical-align: top; width: 33.33%; }
    </style>
</head>
<body onload="window.print()">
    <table class="layout-table">
        <tr>
            <td style="width: 45%;">
                <div class="font-bold">Đơn vị: Công ty Cổ phần Phần mềm BRAVO</div>
                <div><span class="font-bold">Địa chỉ:</span> Tầng 7, Tòa Nhà Văn Phòng 311-313, Đường Trường Chinh, Phường Phương Liệt, Hà Nội.</div>
            </td>
            <td style="width: 55%;" class="text-center">
                <div class="font-bold">Mẫu số S02c1-DN</div>
                <div class="font-italic">(Kèm theo Thông tư số 200/2014/TT-BTC ngày 22 tháng 12 năm 2014 của Bộ trưởng Bộ Tài chính)</div>
            </td>
        </tr>
    </table>

    <div class="title">SỔ CÁI</div>
    <div class="text-center font-bold">(Dùng cho hình thức kế toán Chứng từ ghi sổ)</div>
    
    <div class="text-center" style="margin-top: 10px;">
        Năm: @Model.FromDate.Year<br>
        Tên tài khoản: .................................<br>
        Số hiệu: @Model.AccountNumber
    </div>

    <table class="data-table">
        <thead>
            <tr>
                <th rowspan="2" style="width: 10%;">Ngày,<br>tháng ghi sổ</th>
                <th colspan="2" style="width: 20%;">Chứng từ ghi sổ</th>
                <th rowspan="2" style="width: 25%;">Diễn giải</th>
                <th rowspan="2" style="width: 10%;">Số hiệu TK<br>đối ứng</th>
                <th colspan="2" style="width: 20%;">Số tiền</th>
                <th rowspan="2" style="width: 10%;">Số dư<br>lũy kế</th>
            </tr>
            <tr>
                <th>Số hiệu</th>
                <th>Ngày, tháng</th>
                <th>Nợ</th>
                <th>Có</th>
            </tr>
            <tr>
                <th class="text-center">A</th><th class="text-center">B</th><th class="text-center">C</th><th class="text-center">D</th><th class="text-center">E</th><th class="text-center">1</th><th class="text-center">2</th><th class="text-center">G</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td></td><td></td><td></td>
                <td class="font-bold">- Số dư đầu kỳ</td>
                <td></td><td></td><td></td>
                <td class="text-right font-bold">@Model.OpeningBalance.ToString("N0")</td>
            </tr>
            <tr>
                <td></td><td></td><td></td>
                <td class="font-bold">- Số phát sinh trong kỳ</td>
                <td></td><td></td><td></td><td></td>
            </tr>
            
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td class="text-center">@row.Date.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">@row.VoucherCode</td>
                    <td class="text-center">@row.Date.ToString("dd/MM/yyyy")</td>
                    <td>@row.Description</td>
                    <td class="text-center">@row.CorrespondingAccount</td>
                    <td class="text-right">@(row.Debit > 0 ? row.Debit.ToString("N0") : "")</td>
                    <td class="text-right">@(row.Credit > 0 ? row.Credit.ToString("N0") : "")</td>
                    <td class="text-right">@row.Balance.ToString("N0")</td>
                </tr>
            }

            <tr>
                <td></td><td></td><td></td>
                <td class="font-bold">- Cộng số phát sinh kỳ</td>
                <td class="text-center">x</td>
                <td class="text-right font-bold">@Model.Rows.Sum(x => x.Debit).ToString("N0")</td>
                <td class="text-right font-bold">@Model.Rows.Sum(x => x.Credit).ToString("N0")</td>
                <td class="text-center">x</td>
            </tr>
            <tr>
                <td></td><td></td><td></td>
                <td class="font-bold">- Số dư cuối kỳ</td>
                <td class="text-center">x</td>
                <td class="text-right font-bold"></td>
                <td class="text-right font-bold"></td>
                <td class="text-right font-bold text-[#1d4ed8]">@Model.ClosingBalance.ToString("N0")</td>
            </tr>
        </tbody>
    </table>

    <div style="margin-bottom: 20px;">
        - Sổ này có .... trang, đánh số từ trang số 01 đến trang ...<br>
        - Ngày mở sổ: @DateTime.Now.ToString("dd/MM/yyyy")
    </div>

    <table class="signature-table">
        <tr>
            <td>
                <div class="font-bold">Người ghi sổ</div>
                <div class="font-italic">(Ký, họ tên)</div>
            </td>
            <td>
                <div class="font-bold">Kế toán trưởng</div>
                <div class="font-italic">(Ký, họ tên)</div>
            </td>
            <td>
                <div class="font-italic">Ngày @DateTime.Now.Day tháng @DateTime.Now.Month năm @DateTime.Now.Year</div>
                <div class="font-bold">Người đại diện theo pháp luật</div>
                <div class="font-italic">(Ký, họ tên, đóng dấu)</div>
            </td>
        </tr>
    </table>
</body>
</html>