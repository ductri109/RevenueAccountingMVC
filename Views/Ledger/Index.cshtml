@model List<RevenueAccountingMVC.Models.JournalEntry>

@{
    ViewData["Title"] = "Sổ Nhật Ký Chung";
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var selectedAccountId = ViewBag.AccountId as int?;
    var accounts = ViewBag.Accounts as List<RevenueAccountingMVC.Models.Account>;
    var sortBy = ViewBag.SortBy as string ?? "date";
    // Kiểm tra xem người dùng đã bấm lọc chưa (nếu có FromDate thì coi như đã lọc)
    var hasSearched = fromDate.HasValue; 
}

<div class="p-6 md:p-10 bg-[#f8fafc] min-h-screen">
    <!-- Phần Header và Menu -->
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-[24px] font-bold text-gray-900">Sổ Nhật Ký Chung</h2>
        <p class="text-[14px] text-gray-500 mt-1">Tra cứu và xem chi tiết danh sách các bút toán phát sinh theo thứ tự thời gian</p>
        
        <!-- Gọi Menu dùng chung -->
        <partial name="_ReportTabs" />
    </div>

    <div class="flex flex-col md:flex-row gap-6">
        <!-- Sidebar Bộ Lọc -->
        <div class="w-full md:w-1/4 bg-white rounded-[16px] shadow-sm p-6 border border-gray-100 h-fit">
            <h3 class="font-bold text-gray-800 mb-4 flex items-center">
                <i class="fas fa-filter mr-2"></i> Bộ lọc báo cáo
            </h3>
            
            <form asp-action="Index" method="get">
                <!-- Từ ngày -->
                <div class="mb-4">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Từ ngày</label>
                    <input type="date" name="fromDate" 
                           value="@fromDate?.ToString("yyyy-MM-dd")" 
                           class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none transition-colors" />
                </div>

                <!-- Đến ngày -->
                <div class="mb-4">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Đến ngày</label>
                    <input type="date" name="toDate" 
                           value="@toDate?.ToString("yyyy-MM-dd")" 
                           class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none transition-colors" />
                </div>

                <!-- Tài khoản -->
                <div class="mb-4">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Tài khoản</label>
                    <select name="accountId" class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none transition-colors">
                        <option value="">-- Tất cả tài khoản --</option>
                        @if (accounts != null)
                        {
                            @foreach (var account in accounts)
                            {
                                if (selectedAccountId == account.Id)
                                {
                                    <option value="@account.Id" selected>@account.AccountNumber - @account.AccountName</option>
                                }
                                else
                                {
                                    <option value="@account.Id">@account.AccountNumber - @account.AccountName</option>
                                }
                            }
                        }
                    </select>
                </div>

                <!-- Sắp xếp -->
                <div class="mb-6">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Sắp xếp theo</label>
                    <select name="sortBy" class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none transition-colors">
                        @if(sortBy == "date") { <option value="date" selected>Ngày phát sinh</option> } else { <option value="date">Ngày phát sinh</option> }
                        @if(sortBy == "account") { <option value="account" selected>Tài khoản</option> } else { <option value="account">Tài khoản</option> }
                        @if(sortBy == "voucher") { <option value="voucher" selected>Số chứng từ</option> } else { <option value="voucher">Số chứng từ</option> }
                    </select>
                </div>

                @if (!ViewData.ModelState.IsValid && hasSearched)
                {
                    <div asp-validation-summary="All" class="text-red-500 text-[12px] mb-4"></div>
                }

                <div class="flex flex-col gap-2">
                    <button type="submit" class="w-full bg-black hover:bg-gray-800 text-white py-2.5 rounded-lg text-[14px] font-bold transition-all shadow-md">
                        Lọc / Xem báo cáo
                    </button>
                    
                    @if (hasSearched && Model.Any())
                    {
                        <a href="@Url.Action("PrintJournal", "Ledger", new { fromDate = fromDate?.ToString("yyyy-MM-dd"), toDate = toDate?.ToString("yyyy-MM-dd"), accountId = selectedAccountId, sortBy = sortBy })" target="_blank" class="w-full bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-lg text-[14px] font-bold transition-all shadow-md text-center inline-block">
                            <i class="fas fa-print mr-1"></i> Xuất PDF / In
                        </a>
                    }
                </div>
            </form>
        </div>

        <!-- Nội dung chính: Bảng Dữ Liệu -->
        <div class="w-full md:w-3/4">
            @if (hasSearched)
            {
                if (!Model.Any())
                {
                    <div class="bg-white rounded-[16px] shadow-sm p-10 text-gray-400 text-center border border-gray-100 h-full flex flex-col justify-center items-center min-h-[300px]">
                        <i class="fas fa-inbox text-4xl mb-3 text-gray-300"></i>
                        <p class="text-[16px] font-semibold text-gray-600">Không có dữ liệu phù hợp</p>
                        <p class="text-[14px] mt-1">Vui lòng thay đổi điều kiện tìm kiếm.</p>
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-[16px] shadow-sm border border-gray-100 overflow-hidden">
                        <!-- Thông tin tóm tắt đầu kỳ -->
                        <div class="p-5 border-b border-gray-100 bg-[#f9fafb] flex justify-between items-center">
                            <div class="text-[14px] text-gray-700">
                                <span class="font-bold text-gray-900">Khoảng thời gian:</span> @fromDate?.ToString("dd/MM/yyyy") - @toDate?.ToString("dd/MM/yyyy")
                            </div>
                            <div class="text-[14px] text-gray-700">
                                <span class="font-bold text-gray-900">Tổng số bút toán:</span> <span class="text-blue-600 font-bold">@Model.Count</span>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-[13px]">
                                <thead class="bg-white text-gray-600 font-medium border-b border-gray-200">
                                    <tr>
                                        <th class="py-4 px-4 text-center">Ngày</th>
                                        <th class="py-4 px-4 text-center">Số chứng từ</th>
                                        <th class="py-4 px-4 text-center">Loại chứng từ</th>
                                        <th class="py-4 px-4 text-center">Tài khoản</th>
                                        <th class="py-4 px-4">Diễn giải</th>
                                        <th class="py-4 px-4 text-right">Nợ</th>
                                        <th class="py-4 px-4 text-right">Có</th>
                                        <th class="py-4 px-4 text-center">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var entry in Model)
                                    {
                                        <tr class="hover:bg-gray-50 transition-colors cursor-pointer" onclick="openDetail(@entry.Id)">
                                            <td class="py-3 px-4 text-center text-gray-600 font-medium">@entry.PostingDate.ToString("dd/MM/yyyy")</td>
                                            <td class="py-3 px-4 text-center font-semibold text-blue-600">@entry.VoucherCode</td>
                                            <td class="py-3 px-4 text-center">
                                                <span class="inline-block px-2 py-1 text-[11px] font-bold rounded-md
                                                    @(entry.VoucherType == "SalesVoucher" ? "bg-blue-50 text-blue-600 border border-blue-200" : "bg-orange-50 text-orange-600 border border-orange-200")">
                                                    @(entry.VoucherType == "SalesVoucher" ? "Hóa đơn" : "Giảm giá")
                                                </span>
                                            </td>
                                            <td class="py-3 px-4 text-center font-semibold text-gray-800">@entry.Account?.AccountNumber</td>
                                            <td class="py-3 px-4 text-gray-600">@entry.Description</td>
                                            
                                            <!-- Số tiền Nợ -->
                                            <td class="py-3 px-4 text-right">
                                                @if (entry.EntryType == "Debit")
                                                {
                                                    <span class="font-semibold text-gray-900">@entry.Amount.ToString("N0")</span>
                                                }
                                                else { <span class="text-gray-400">-</span> }
                                            </td>
                                            
                                            <!-- Số tiền Có -->
                                            <td class="py-3 px-4 text-right">
                                                @if (entry.EntryType == "Credit")
                                                {
                                                    <span class="font-semibold text-gray-900">@entry.Amount.ToString("N0")</span>
                                                }
                                                else { <span class="text-gray-400">-</span> }
                                            </td>
                                            
                                            <td class="py-3 px-4 text-center">
                                                <a href="@Url.Action("VoucherDetail", new { voucherId = entry.VoucherId, voucherType = entry.VoucherType })" 
                                                   class="text-blue-600 hover:text-blue-800 font-semibold text-[12px] inline-flex items-center"
                                                   onclick="event.stopPropagation();">
                                                    <i class="fas fa-eye mr-1"></i> Xem
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-[#f9fafb] border-t border-gray-200">
                                    <tr>
                                        <td colspan="5" class="py-4 px-4 font-bold text-center text-gray-900">Tổng cộng phát sinh</td>
                                        <td class="py-4 px-4 text-right font-bold text-gray-900">@Model.Where(x => x.EntryType == "Debit").Sum(x => x.Amount).ToString("N0")</td>
                                        <td class="py-4 px-4 text-right font-bold text-gray-900">@Model.Where(x => x.EntryType == "Credit").Sum(x => x.Amount).ToString("N0")</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-[16px] shadow-sm p-10 text-gray-400 text-center border border-gray-100 h-full flex flex-col justify-center items-center min-h-[300px]">
                    <i class="fas fa-book-open text-4xl mb-3 text-gray-300"></i>
                    <p>Vui lòng chọn thời gian và nhấn "Lọc" để xem Sổ nhật ký chung.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal xem chi tiết bút toán (Giữ nguyên) -->
<div id="detailModal" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center z-50">
    <div class="bg-white rounded-[16px] w-11/12 md:w-2/3 max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center">
            <h3 class="text-[18px] font-bold">Chi tiết bút toán</h3>
            <button onclick="closeDetail()" class="text-gray-400 hover:text-gray-600 text-[24px]">×</button>
        </div>
        <div id="detailContent" class="p-6">
            <!-- Nội dung sẽ được load bằng AJAX -->
        </div>
    </div>
</div>

<script>
    function openDetail(entryId) {
        fetch(`@Url.Action("EntryDetail")/${entryId}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById('detailContent').innerHTML = html;
                document.getElementById('detailModal').classList.remove('hidden');
            });
    }

    function closeDetail() {
        document.getElementById('detailModal').classList.add('hidden');
    }

    document.getElementById('detailModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeDetail();
        }
    });
</script>