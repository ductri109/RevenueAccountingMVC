@{
    ViewData["Title"] = "Chi Tiết Doanh Thu Khách Hàng";
    var customer = ViewBag.Customer as RevenueAccountingMVC.Models.Customer;
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var salesVouchers = ViewBag.SalesVouchers as List<RevenueAccountingMVC.Models.SalesVoucher>;
    var adjustments = ViewBag.Adjustments as List<RevenueAccountingMVC.Models.RevenueAdjustment>;
    var totalRevenue = ViewBag.TotalRevenue as decimal?;
    var totalTax = ViewBag.TotalTax as decimal?;
    var adjustmentAmount = ViewBag.AdjustmentAmount as decimal?;
    var netRevenue = ViewBag.NetRevenue as decimal?;
}

<div class="p-6 md:p-10 bg-[#f8fafc] min-h-screen">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-2 mb-4">
            <a href="@Url.Action("RevenueByCustomer")" class="text-blue-600 hover:text-blue-800 font-semibold text-[14px]">
                <i class="fas fa-arrow-left mr-1"></i> Quay lại
            </a>
        </div>
        <h2 class="text-[24px] font-bold text-gray-900">Chi Tiết Doanh Thu - @customer?.CustomerName</h2>
        <p class="text-[14px] text-gray-500 mt-1">Danh sách các chứng từ bán hàng và giảm giá liên quan</p>
    </div>

    <!-- Thông tin khách hàng -->
    <div class="bg-white rounded-[16px] shadow-sm p-6 border border-gray-100 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div>
                <span class="block text-[12px] font-semibold text-gray-600 uppercase mb-1">Mã Khách Hàng</span>
                <span class="text-[18px] font-bold text-gray-900">@customer?.CustomerCode</span>
            </div>
            <div>
                <span class="block text-[12px] font-semibold text-gray-600 uppercase mb-1">Tên Khách Hàng</span>
                <span class="text-[16px] font-semibold text-gray-900">@customer?.CustomerName</span>
            </div>
            <div>
                <span class="block text-[12px] font-semibold text-gray-600 uppercase mb-1">Mã Số Thuế</span>
                <span class="text-[14px] text-gray-700">@(customer?.TaxCode ?? "-")</span>
            </div>
            <div>
                <span class="block text-[12px] font-semibold text-gray-600 uppercase mb-1">Khoảng Thời Gian</span>
                <span class="text-[14px] text-gray-700">@fromDate?.ToString("dd/MM/yyyy") - @toDate?.ToString("dd/MM/yyyy")</span>
            </div>
        </div>

        <div class="mt-6 pt-6 border-t border-gray-100">
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                <div>
                    <div class="text-[12px] text-gray-600 font-semibold">Tổng Doanh Thu</div>
                    <div class="text-[16px] font-bold text-gray-900">@totalRevenue?.ToString("N0")</div>
                </div>
                <div>
                    <div class="text-[12px] text-gray-600 font-semibold">Tổng Thuế</div>
                    <div class="text-[16px] font-bold text-gray-900">@totalTax?.ToString("N0")</div>
                </div>
                <div>
                    <div class="text-[12px] text-gray-600 font-semibold">DT Giảm</div>
                    <div class="text-[16px] font-bold text-red-600">@adjustmentAmount?.ToString("N0")</div>
                </div>
                <div>
                    <div class="text-[12px] text-gray-600 font-semibold">DT Ròng</div>
                    <div class="text-[16px] font-bold text-blue-600">@netRevenue?.ToString("N0")</div>
                </div>
                <div>
                    <div class="text-[12px] text-gray-600 font-semibold">Số Giao Dịch</div>
                    <div class="text-[16px] font-bold text-gray-900">@((salesVouchers?.Count ?? 0) + (adjustments?.Count ?? 0))</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách Hóa đơn bán hàng -->
    @if (salesVouchers?.Any() == true)
    {
        <div class="bg-white rounded-[16px] shadow-sm border border-gray-100 overflow-hidden mb-6">
            <div class="p-6 border-b border-gray-100 bg-[#f9fafb]">
                <h3 class="text-[16px] font-bold text-gray-900">Hóa Đơn Bán Hàng (@salesVouchers.Count)</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-[13px]">
                    <thead class="bg-[#f9fafb] text-gray-600 font-medium border-b border-gray-100">
                        <tr>
                            <th class="py-3 px-4">Ngày</th>
                            <th class="py-3 px-4">Số HĐ</th>
                            <th class="py-3 px-4">Sản Phẩm</th>
                            <th class="py-3 px-4 text-right">SL</th>
                            <th class="py-3 px-4 text-right">Thành Tiền</th>
                            <th class="py-3 px-4 text-right">Thuế</th>
                            <th class="py-3 px-4 text-right">Tổng TT</th>
                            <th class="py-3 px-4">Trạng Thái</th>
                            <th class="py-3 px-4 text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var voucher in salesVouchers)
                        {
                            var voucherTotal = voucher.Details.Sum(x => x.Amount + x.TaxAmount);
                            @foreach (var detail in voucher.Details)
                            {
                                <tr class="hover:bg-gray-50/50">
                                    <td class="py-3 px-4 font-medium">@voucher.AccountingDate.ToString("dd/MM/yyyy")</td>
                                    <td class="py-3 px-4 font-semibold text-blue-600">@voucher.VoucherCode</td>
                                    <td class="py-3 px-4">@detail.Product?.ProductName</td>
                                    <td class="py-3 px-4 text-right">@detail.Quantity</td>
                                    <td class="py-3 px-4 text-right">@detail.Amount.ToString("N0")</td>
                                    <td class="py-3 px-4 text-right">@detail.TaxAmount.ToString("N0")</td>
                                    <td class="py-3 px-4 text-right font-semibold">@(detail.Amount + detail.TaxAmount).ToString("N0")</td>
                                    <td class="py-3 px-4">
                                        <span class="inline-block px-3 py-1 text-[12px] font-semibold rounded-full bg-green-100 text-green-700">
                                            Đã ghi sổ
                                        </span>
                                    </td>
                                    <td class="py-3 px-4 text-center">
                                        <a href="@Url.Action("Edit", "SalesVoucher", new { id = voucher.Id })" 
                                           class="text-blue-600 hover:text-blue-800 font-semibold text-[12px]">
                                            <i class="fas fa-eye mr-1"></i> Xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Danh sách Chứng từ Giảm Giá -->
    @if (adjustments?.Any() == true)
    {
        <div class="bg-white rounded-[16px] shadow-sm border border-gray-100 overflow-hidden mb-6">
            <div class="p-6 border-b border-gray-100 bg-[#f9fafb]">
                <h3 class="text-[16px] font-bold text-gray-900">Chứng Từ Giảm Giá (@adjustments.Count)</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-[13px]">
                    <thead class="bg-[#f9fafb] text-gray-600 font-medium border-b border-gray-100">
                        <tr>
                            <th class="py-3 px-4">Ngày</th>
                            <th class="py-3 px-4">Số CTGG</th>
                            <th class="py-3 px-4">Loại Giảm</th>
                            <th class="py-3 px-4">Sản Phẩm</th>
                            <th class="py-3 px-4 text-right">SL</th>
                            <th class="py-3 px-4 text-right">Tiền Giảm</th>
                            <th class="py-3 px-4 text-right">Thuế Giảm</th>
                            <th class="py-3 px-4 text-right">Tổng Giảm</th>
                            <th class="py-3 px-4 text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var adjustment in adjustments)
                        {
                            @foreach (var detail in adjustment.Details)
                            {
                                <tr class="hover:bg-gray-50/50">
                                    <td class="py-3 px-4 font-medium">@adjustment.AccountingDate.ToString("dd/MM/yyyy")</td>
                                    <td class="py-3 px-4 font-semibold text-orange-600">@adjustment.AdjustmentCode</td>
                                    <td class="py-3 px-4">
                                        <span class="inline-block px-2 py-1 text-[12px] font-semibold rounded-full
                                            @(detail.AdjustmentType == "Discount" ? "bg-blue-100 text-blue-700" : "bg-purple-100 text-purple-700")">
                                            @(detail.AdjustmentType == "Discount" ? "Chiết khấu" : "Trả hàng")
                                        </span>
                                    </td>
                                    <td class="py-3 px-4">@detail.Product?.ProductName</td>
                                    <td class="py-3 px-4 text-right">@Math.Abs(detail.Quantity)</td>
                                    <td class="py-3 px-4 text-right text-red-600">@Math.Abs(detail.Amount).ToString("N0")</td>
                                    <td class="py-3 px-4 text-right text-red-600">@Math.Abs(detail.TaxAmount).ToString("N0")</td>
                                    <td class="py-3 px-4 text-right font-semibold text-red-600">@(Math.Abs(detail.Amount) + Math.Abs(detail.TaxAmount)).ToString("N0")</td>
                                    <td class="py-3 px-4 text-center">
                                        <a href="@Url.Action("Edit", "RevenueAdjustment", new { id = adjustment.Id })" 
                                           class="text-blue-600 hover:text-blue-800 font-semibold text-[12px]">
                                            <i class="fas fa-eye mr-1"></i> Xem
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Không có dữ liệu -->
    @if ((salesVouchers?.Count ?? 0) == 0 && (adjustments?.Count ?? 0) == 0)
    {
        <div class="bg-white rounded-[16px] shadow-sm p-12 border border-gray-100 text-center">
            <i class="fas fa-inbox text-gray-300 text-[48px] mb-4"></i>
            <p class="text-[16px] text-gray-600 font-semibold">Không có chứng từ</p>
            <p class="text-[14px] text-gray-500 mt-2">Khách hàng này không có chứng từ nào trong khoảng thời gian này</p>
        </div>
    }
</div>
