@model IEnumerable<RevenueAccountingMVC.Models.RevenueByProductReportLine>
@{
    ViewData["Title"] = "Báo cáo doanh thu theo mặt hàng";
    var hasSearched = ViewBag.HasSearched as bool? ?? false;
}

<div class="p-6 md:p-10 bg-[#f8fafc] min-h-screen">
    <div class="mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-[24px] font-bold text-gray-900">Báo cáo doanh thu theo mặt hàng</h2>
        <p class="text-[14px] text-gray-500 mt-1">Xem và phân tích doanh thu bán ra theo từng sản phẩm/hàng hoá</p>
        <!-- Menu Tabs Navigation -->
        <partial name="_ReportTabs" />
    </div>

    <div class="flex flex-col md:flex-row gap-6">
        <!-- Sidebar Filter -->
        <div class="w-full md:w-1/4 bg-white rounded-[16px] shadow-sm p-6 border border-gray-100 h-fit">
            <h3 class="font-bold text-gray-800 mb-4 flex items-center">
                <i class="fas fa-filter mr-2"></i> Bộ lọc báo cáo
            </h3>
            
            <form asp-action="RevenueByProduct" method="get">
                <div class="mb-4">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Từ ngày</label>
                    <input type="date" name="fromDate" value="@(ViewBag.FromDate != null ? ((DateTime)ViewBag.FromDate).ToString("yyyy-MM-dd") : "")" class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none" required />
                </div>
                <div class="mb-4">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Đến ngày</label>
                    <input type="date" name="toDate" value="@(ViewBag.ToDate != null ? ((DateTime)ViewBag.ToDate).ToString("yyyy-MM-dd") : "")" class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none" required />
                </div>
                <div class="mb-6">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-2">Mã sản phẩm</label>
                    <select name="productId" class="w-full bg-[#f3f4f6] border border-transparent focus:border-gray-400 rounded-lg px-4 py-2 text-[14px] outline-none">
                        <option value="">-- Tất cả sản phẩm --</option>
                        @foreach (var p in ViewBag.Products)
                        {
                            if (ViewBag.SelectedProductId != null && ViewBag.SelectedProductId == p.Id)
                            {
                                <option value="@p.Id" selected>@p.ProductCode - @p.ProductName</option>
                            }
                            else
                            {
                                <option value="@p.Id">@p.ProductCode - @p.ProductName</option>
                            }
                        }
                    </select>
                </div>
                
                @if (!ViewData.ModelState.IsValid && hasSearched)
                {
                    <div asp-validation-summary="All" class="text-red-500 text-sm mb-4"></div>
                }

                <div class="flex flex-col gap-2">
                    <button type="submit" class="w-full bg-black hover:bg-gray-800 text-white py-2.5 rounded-lg text-[14px] font-bold transition-all shadow-md">
                        Lọc
                    </button>
                    @if (hasSearched && Model.Any())
                    {
                        <a href="@Url.Action("PrintRevenueByProduct", "Ledger", new { fromDate = ((DateTime)ViewBag.FromDate).ToString("yyyy-MM-dd"), toDate = ((DateTime)ViewBag.ToDate).ToString("yyyy-MM-dd"), productId = ViewBag.SelectedProductId })" target="_blank" class="w-full bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-lg text-[14px] font-bold transition-all shadow-md text-center">
                            <i class="fas fa-print mr-1"></i> Xuất PDF / In
                        </a>
                    }
                </div>
            </form>
        </div>

        <!-- Main Content (Data Table) -->
        <div class="w-full md:w-3/4">
            @if (hasSearched)
            {
                if (!Model.Any())
                {
                    <div class="bg-white rounded-[16px] shadow-sm p-6 text-gray-500 text-center border border-gray-100">
                        Không có dữ liệu phù hợp trong khoảng thời gian này.
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-[16px] shadow-sm border border-gray-100 overflow-hidden">
                        <table class="w-full text-left text-[13px]">
                            <thead class="bg-[#f9fafb] text-gray-600 font-medium border-b border-gray-100">
                                <tr>
                                    <th class="py-4 px-4 text-center">Mã HH</th>
                                    <th class="py-4 px-4">Tên hàng hóa</th>
                                    <th class="py-4 px-4 text-right">Số lượng</th>
                                    <th class="py-4 px-4 text-right">Doanh thu</th>
                                    <th class="py-4 px-4 text-center">Hành động</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="py-3 px-4 text-center font-semibold">@item.ProductCode</td>
                                    <td class="py-3 px-4">@item.ProductName</td>
                                    <!-- Dùng Quantity cho Số lượng -->
                                    <td class="py-3 px-4 text-right">@item.Quantity.ToString("N2")</td>
                                    <!-- Dùng TotalRevenue (hoặc NetRevenue) cho Doanh thu -->
                                    <td class="py-3 px-4 text-right font-semibold text-blue-600">@item.TotalRevenue.ToString("N0")</td>
                                    <td class="py-3 px-4 text-center">
                                        <a href="#" class="text-blue-500 hover:underline">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-[#f9fafb] border-t border-gray-200">
                            <tr>
                                <td colspan="2" class="py-4 px-4 font-bold text-center">Tổng cộng</td>
                                <td class="py-4 px-4 text-right font-bold">@Model.Sum(x => x.Quantity).ToString("N2")</td>
                                <td class="py-4 px-4 text-right font-bold text-blue-700">@Model.Sum(x => x.TotalRevenue).ToString("N0")</td>
                                <td></td>
                            </tr>
                        </tfoot>    
                        </table>
                    </div>
                }
            }
            else
            {
                <div class="bg-white rounded-[16px] shadow-sm p-10 text-gray-400 text-center border border-gray-100 h-full flex flex-col justify-center items-center">
                    <i class="fas fa-chart-bar text-4xl mb-3"></i>
                    <p>Vui lòng chọn thời gian và nhấn "Lọc" để xem báo cáo.</p>
                </div>
            }
        </div>
    </div>
</div>