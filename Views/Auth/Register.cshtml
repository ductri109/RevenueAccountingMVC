@model RevenueAccountingMVC.Models.RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký Kế toán - Hệ thống</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-[#f4f7f9] min-h-screen flex items-center justify-center py-10">
    <div class="bg-white w-full max-w-lg p-8 rounded-2xl shadow-sm border border-gray-100">
        <div class="mb-8">
            <h1 class="text-[22px] font-bold text-gray-900">Đăng ký tài khoản</h1>
            <p class="text-sm text-gray-500 mt-1">Tạo tài khoản dành cho nghiệp vụ Kế toán</p>
        </div>

        <form asp-action="Register" method="post" class="space-y-5">
            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Họ và tên</label>
                <input asp-for="FullName" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Email</label>
                <input asp-for="Email" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" placeholder="email@congty.com" />
                <span asp-validation-for="Email" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[14px] font-medium text-gray-700 mb-1">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" />
                    <span asp-validation-for="Password" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-[14px] font-medium text-gray-700 mb-1">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>
            </div>

            <button type="submit" class="w-full mt-2 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-lg text-[14px] transition-colors shadow-sm">
                Đăng ký ngay
            </button>
        </form>

        <div class="mt-6 text-center text-[14px] text-gray-600">
            Đã có tài khoản? <a asp-action="Login" class="text-blue-600 font-medium hover:underline">Đăng nhập</a>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>