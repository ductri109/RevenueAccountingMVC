@model RevenueAccountingMVC.Models.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - Hệ thống Kế toán</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-[#f4f7f9] h-screen flex items-center justify-center">
    <div class="bg-white w-full max-w-md p-8 rounded-2xl shadow-sm border border-gray-100">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mx-auto mb-4">
                <i data-lucide="calculator" class="w-6 h-6"></i>
            </div>
            <h1 class="text-[22px] font-bold text-gray-900">Nghiệp vụ Kế toán</h1>
            <p class="text-sm text-gray-500 mt-1">Dành cho Admin và Kế toán viên</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-4 p-3 bg-green-50 text-green-700 text-sm rounded-lg border border-green-200 text-center">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Email</label>
                <input asp-for="Email" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" placeholder="Nhập email của bạn" />
                <span asp-validation-for="Email" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Mật khẩu</label>
                <input asp-for="Password" type="password" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-lg text-[14px] transition-colors shadow-sm">
                Đăng nhập hệ thống
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 flex flex-col gap-3 text-center text-[14px]">
            <a asp-action="Register" class="text-gray-600 hover:text-blue-600 font-medium transition-colors">Đăng ký tài khoản Kế toán mới</a>
            <a asp-action="LoginLeader" class="text-gray-500 hover:text-gray-900 flex items-center justify-center gap-1 transition-colors">
                <i data-lucide="briefcase" class="w-4 h-4"></i> Cổng đăng nhập dành cho Lãnh đạo
            </a>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>