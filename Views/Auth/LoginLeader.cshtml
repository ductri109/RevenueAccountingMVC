@model RevenueAccountingMVC.Models.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cổng Lãnh Đạo - Hệ thống Kế toán</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-[#0f172a] h-screen flex items-center justify-center"> <div class="bg-white w-full max-w-md p-8 rounded-2xl shadow-xl">
        <div class="text-center mb-8">
            <div class="w-12 h-12 bg-[#0f172a] text-white rounded-xl flex items-center justify-center mx-auto mb-4 shadow-md">
                <i data-lucide="shield-check" class="w-6 h-6"></i>
            </div>
            <h1 class="text-[22px] font-bold text-gray-900">Cổng Quản Trị Lãnh Đạo</h1>
            <p class="text-sm text-gray-500 mt-1">Hệ thống báo cáo & duyệt doanh thu</p>
        </div>

        <form asp-action="LoginLeader" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Email lãnh đạo</label>
                <input asp-for="Email" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-[#0f172a] focus:ring-1 focus:ring-[#0f172a] rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" />
                <span asp-validation-for="Email" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <div>
                <label class="block text-[14px] font-medium text-gray-700 mb-1">Mật khẩu</label>
                <input asp-for="Password" type="password" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-[#0f172a] focus:ring-1 focus:ring-[#0f172a] rounded-lg px-4 py-2.5 text-[14px] outline-none transition-all" />
                <span asp-validation-for="Password" class="text-red-500 text-[12px] mt-1 block"></span>
            </div>

            <button type="submit" class="w-full bg-[#0f172a] hover:bg-gray-800 text-white font-medium py-2.5 rounded-lg text-[14px] transition-colors shadow-sm">
                Xác thực đăng nhập
            </button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center">
            <a asp-action="Login" class="text-gray-500 hover:text-gray-900 text-[14px] inline-flex items-center gap-1 transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Quay lại cổng Kế toán
            </a>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>