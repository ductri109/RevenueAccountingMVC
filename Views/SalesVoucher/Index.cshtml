@using RevenueAccountingMVC.Models
@model IEnumerable<SalesVoucher>

@{
    ViewData["Title"] = "Quản lý doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Khởi tạo các biến phân trang từ Controller truyền sang
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    int totalItems = ViewData["TotalItems"] != null ? (int)ViewData["TotalItems"] : 0;
    string currentSearch = ViewData["CurrentSearch"]?.ToString();
    
    // Lấy tổng tiền toàn bộ danh sách (đã lọc)
    decimal totalAmount = ViewData["TotalAmount"] != null ? (decimal)ViewData["TotalAmount"] : 0;
}

<div class="p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-[22px] font-bold text-gray-900">Danh sách chứng từ bán hàng</h2>
            <p class="text-[14px] text-gray-500 mt-1">Quản lý hóa đơn và ghi nhận doanh thu</p>
        </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-4 flex items-center gap-3 shadow-sm mb-6">
        <a asp-action="Create" class="bg-[#0f172a] hover:bg-gray-800 text-white px-5 py-2.5 rounded-lg text-[14px] font-medium inline-flex items-center gap-2 transition-colors active:scale-95 shadow-md">
            <i data-lucide="plus-circle" class="w-4 h-4"></i> Ghi nhận mới
        </a>

        <form asp-action="Index" method="get" class="flex items-center gap-3 flex-1 ml-4">
            <div class="relative w-[350px]">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
                </div>
                <input type="text" name="searchString" value="@currentSearch" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg pl-9 pr-4 py-2.5 text-[14px] outline-none transition-all" placeholder="Tìm số chứng từ, khách hàng...">
            </div>
            <button type="submit" class="bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 shadow-sm">
                Tìm kiếm
            </button>
            <a asp-action="Index" class="bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 transition-colors cursor-pointer shadow-sm ml-auto">
                <i data-lucide="refresh-cw" class="w-4 h-4 text-gray-600"></i> Làm mới
            </a>
        </form>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-left text-[14px]">
            <thead class="border-b border-gray-200 bg-gray-50">
                <tr>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Ngày HT</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Số CT</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Mã KH</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Khách hàng</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Diễn giải</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-right">Tổng thanh toán</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                
                @* ĐÃ SỬA: Dòng tổng lấy từ Controller để tính tổng của tất cả trang thay vì chỉ trang hiện tại *@
                <tr class="bg-gray-50/50 font-semibold text-gray-900">
                    <td colspan="5" class="py-3 px-5 text-[14px]">Tổng cộng toàn bộ dữ liệu</td>
                    <td class="py-3 px-5 text-right text-[14px] text-black-700 font-bold">
                        @totalAmount.ToString("N0") đ
                    </td>
                    <td></td>
                </tr>

                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-5 text-gray-600 font-medium">@item.AccountingDate.ToString("dd/MM/yyyy")</td>
                            <td class="py-4 px-5 font-bold text-blue-700">@item.VoucherCode</td>
                            <td class="py-4 px-5 text-gray-900 font-medium">@(item.Customer?.CustomerCode)</td>
                            <td class="py-4 px-5 text-gray-900 font-medium">@item.CustomerNameSnapshot</td>
                            <td class="py-4 px-5 text-gray-500 truncate max-w-[200px]" title="@item.Description">@item.Description</td>
                            <td class="py-4 px-5 text-right font-bold text-gray-900">@item.TotalPayment.ToString("N0") đ</td>

                            <td class="py-4 px-5 flex items-center justify-center gap-3">

                                <!-- 👁 XEM CHI TIẾT -->
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="text-gray-400 hover:text-blue-600 transition-colors"
                                   title="Xem chi tiết">
                                    <i data-lucide="eye" class="w-4 h-4"></i>
                                </a>

                                <!-- ✏️ SỬA CHỨNG TỪ -->
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="text-gray-400 hover:text-amber-500 transition-colors"
                                   title="Sửa chứng từ">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a>

                                <!-- 🗑️ XÓA/HỦY CHỨNG TỪ -->
                                <button type="button" onclick="deleteVoucher(@item.Id)"
                                        class="text-gray-400 hover:text-red-600 transition-colors outline-none"
                                        title="Hủy chứng từ">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="py-10 text-center text-gray-500">
                            Chưa có chứng từ nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- KHU VỰC PHÂN TRANG (PAGINATION) -->
    @if (totalPages > 1)
    {
        <div class="mt-4 flex items-center justify-between bg-white px-4 py-3 border border-gray-200 rounded-xl shadow-sm">
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm text-gray-700">
                        Trang <span class="font-medium">@currentPage</span> / <span class="font-medium">@totalPages</span>
                    </p>
                </div>
                <div>
                    <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                        <!-- Nút Previous -->
                        <a asp-action="Index" 
                           asp-route-pageNumber="@(currentPage - 1)" 
                           asp-route-searchString="@currentSearch" 
                           class="relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 @(currentPage == 1 ? "pointer-events-none opacity-50 bg-gray-100" : "cursor-pointer")">
                            <span class="sr-only">Previous</span>
                            <i data-lucide="chevron-left" class="h-4 w-4"></i>
                        </a>
                        
                        <!-- Hiển thị các số trang -->
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a asp-action="Index" 
                               asp-route-pageNumber="@i" 
                               asp-route-searchString="@currentSearch" 
                               class="relative inline-flex items-center px-4 py-2 text-sm font-semibold @(i == currentPage ? "z-10 bg-[#0f172a] text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0f172a]" : "text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 cursor-pointer")">
                                @i
                            </a>
                        }

                        <!-- Nút Next -->
                        <a asp-action="Index" 
                           asp-route-pageNumber="@(currentPage + 1)" 
                           asp-route-searchString="@currentSearch" 
                           class="relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 @(currentPage == totalPages ? "pointer-events-none opacity-50 bg-gray-100" : "cursor-pointer")">
                            <span class="sr-only">Next</span>
                            <i data-lucide="chevron-right" class="h-4 w-4"></i>
                        </a>
                    </nav>
                </div>
            </div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        lucide.createIcons();

        function postVoucher(id) {
            if (confirm("Xác nhận ghi sổ chứng từ này?")) {
                let token = $('input[name="__RequestVerificationToken"]').val();
                
                $.post(`/SalesVoucher/PostVoucher/${id}`, {
                    __RequestVerificationToken: token
                }, function (res) {
                    if (res.success) location.reload();
                    else alert(res.message);
                }).fail(function() {
                    alert("Có lỗi xảy ra khi gọi server.");
                });
            }
        }

        function deleteVoucher(id) {
            if (confirm('Bạn có chắc chắn muốn xóa chứng từ này? Dữ liệu không thể khôi phục.')) {
                let token = $('input[name="__RequestVerificationToken"]').val();

                $.post(`/SalesVoucher/Delete/${id}`, { 
                    __RequestVerificationToken: token 
                }, function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message); 
                    }
                }).fail(function() {
                    alert("Lỗi bảo mật hoặc không thể kết nối đến server.");
                });
            }
        }
    </script>
}