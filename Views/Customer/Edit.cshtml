@using RevenueAccountingMVC.Models
@model Customer

@{
    ViewData["Title"] = "Chỉnh sửa khách hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-8">
    <div class="flex flex-col gap-4 mb-6">
        @* Nút Quay lại nằm trên - Tối giản *@
        <div>
            <a asp-action="Index" class="inline-flex items-center gap-2 text-[14px] font-medium text-gray-500 hover:text-black transition-colors group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i> 
                Quay lại danh sách
            </a>
        </div>

        @* Tiêu đề nằm dưới *@
        <div>
            <h2 class="text-[24px] font-bold text-gray-900">Chỉnh sửa thông tin khách hàng</h2>
        </div>
    </div>

    <div class="bg-white border border-gray-100 rounded-xl shadow-sm p-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <div>
                    <label asp-for="CustomerCode" class="block text-[14px] font-medium text-gray-700 mb-1.5">
                        Mã khách hàng <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="CustomerCode" type="text" 
                           readonly 
                           class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 text-[14px] text-gray-800 font-bold cursor-not-allowed outline-none shadow-sm" />
                    <p class="text-[11px] text-blue-600 mt-1 italic flex items-center gap-1">
                        <i data-lucide="info" class="w-3 h-3 inline mr-0.5"></i> Mã khách hàng do hệ thống tự sinh.
                    </p>
                </div>

                <div>
                    <label asp-for="CustomerName" class="block text-[14px] font-medium text-gray-700 mb-1.5">
                        Tên khách hàng <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="CustomerName" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] text-gray-900 outline-none transition-all" />
                    <span asp-validation-for="CustomerName" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="CustomerType" class="block text-[14px] font-medium text-gray-700 mb-1.5">
                        Loại khách hàng <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="CustomerType" asp-items="Html.GetEnumSelectList<CustomerType>()" class="appearance-none w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-900 cursor-pointer outline-none transition-all">
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                            <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="CustomerType" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="PhoneNumber" class="block text-[14px] font-medium text-gray-700 mb-1.5">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] text-gray-900 outline-none transition-all" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-[14px] font-medium text-gray-700 mb-1.5">Email</label>
                    <input asp-for="Email" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] text-gray-900 outline-none transition-all" />
                    <span asp-validation-for="Email" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>
                
                <div>
                    <label asp-for="TaxCode" class="block text-[14px] font-medium text-gray-700 mb-1.5">Mã số thuế</label>
                    <input asp-for="TaxCode" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] text-gray-900 outline-none transition-all" placeholder="VD: 0312345678" />
                    <span asp-validation-for="TaxCode" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>


                @* --- Dòng Trạng thái và Thời gian hệ thống --- *@
                <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-x-8">
                    @* Cột trái: Trạng thái *@
                    <div>
                        <label asp-for="Status" class="block text-[14px] font-medium text-gray-700 mb-1.5">
                            Trạng thái <span class="text-red-500">*</span>
                        </label>
                        <div class="relative">
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<CustomerStatus>()" class="appearance-none w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-900 cursor-pointer outline-none transition-all">
                            </select>
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                            </div>
                        </div>
                        <span asp-validation-for="Status" class="text-red-500 text-[12px] mt-1 block"></span>
                    </div>

                    @* Cột phải: Chia đôi Ngày tạo & Cập nhật *@
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[14px] font-medium text-gray-700 mb-1.5">Ngày tạo</label>
                            <div class="relative">
                                <input type="text" readonly value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-500 cursor-not-allowed outline-none shadow-sm" />
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <i data-lucide="calendar" class="w-4 h-4 text-gray-400"></i>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[14px] font-medium text-gray-700 mb-1.5">Cập nhật gần nhất</label>
                            <div class="relative">
                                <input type="text" readonly value="@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")" 
                                       class="w-full bg-gray-50 border border-gray-200 rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-500 cursor-not-allowed outline-none shadow-sm" />
                                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                    <i data-lucide="history" class="w-4 h-4 text-gray-400"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Address" class="block text-[14px] font-medium text-gray-700 mb-1.5">Địa chỉ</label>
                    <textarea asp-for="Address" rows="2" class="w-full bg-gray-50 border border-gray-300 focus:bg-white focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] text-gray-900 outline-none transition-all resize-none"></textarea>
                    <span asp-validation-for="Address" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>
            </div>

            <div class="mt-8 border-t border-gray-100 pt-5 flex items-center justify-end gap-3">
                <a asp-action="Index" class="px-5 py-2.5 text-[14px] font-semibold text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                    Huỷ
                </a>
                <button type="submit" class="bg-black hover:bg-gray-800 text-white px-8 py-2.5 rounded-lg text-[14px] font-bold flex items-center gap-2 transition-all shadow-md active:scale-95">
                    <i data-lucide="save" class="w-4 h-4"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}