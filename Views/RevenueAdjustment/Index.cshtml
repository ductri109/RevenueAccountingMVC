@model IEnumerable<RevenueAccountingMVC.Models.RevenueAdjustment>
@{
    ViewData["Title"] = "Quản lý điều chỉnh doanh thu";
}

<div class="min-h-screen font-['Inter'] antialiased text-slate-900">
    <div class="max-w-7xl mx-auto px-6 py-8">
        
        <div class="mb-8">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">Quản lý điều chỉnh doanh thu</h1>
            <p class="text-sm text-slate-500 mt-1">Danh sách các chứng từ ghi giảm doanh thu</p>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="relative w-full md:w-96">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="search" class="w-4 h-4 text-slate-400"></i>
                </div>
                <input type="text" placeholder="Tìm số chứng từ, khách hàng..." 
                       class="block w-full pl-10 pr-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all">
            </div>
            
            <div class="flex items-center gap-3 w-full md:w-auto">
                <a asp-action="Create" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-slate-900 text-white text-sm font-semibold rounded-lg hover:bg-slate-800 shadow-sm transition-all w-full md:w-auto">
                    <i data-lucide="plus" class="w-4 h-4"></i> Ghi giảm
                </a>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 text-[11px] font-bold text-slate-500 uppercase tracking-widest border-b border-slate-100">
                            <th class="px-6 py-4">Số chứng từ điều chỉnh</th>
                            <th class="px-4 py-4">Ngày hạch toán</th>
                            <th class="px-4 py-4">Mã khách hàng</th>
                            <th class="px-4 py-4">Tên khách hàng</th>
                            <th class="px-4 py-4">Diễn giải</th>
                            <th class="px-4 py-4 text-right">Tổng thanh toán</th>
                            <th class="px-6 py-4 text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <tr class="bg-slate-50/30 font-semibold text-slate-900">
                            <td colspan="5" class="px-6 py-3 text-sm">Tổng</td>
                            <td class="px-4 py-3 text-right text-sm">
                                @Model.Sum(x => x.TotalPayment).ToString("N0") đ
                            </td>
                            <td></td>
                        </tr>

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="px-6 py-12 text-center text-slate-400 text-sm">
                                    Không tìm thấy dữ liệu chứng từ phù hợp.
                                </td>
                            </tr>
                        }

                        @foreach (var item in Model)
                        {
                            <tr class="group hover:bg-slate-50/80 transition-colors">
                                <td class="px-6 py-4 text-sm font-bold text-indigo-600">@item.AdjustmentCode</td>
                                <td class="px-4 py-4 text-sm text-slate-600">@item.AccountingDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-4 text-sm text-slate-500">@item.Customer?.CustomerCode</td>
                                <td class="px-4 py-4 text-sm font-medium text-slate-700">@item.Customer?.CustomerName</td>
                                <td class="px-4 py-4 text-sm text-slate-500 truncate max-w-[200px]" title="@item.Description">
                                    @item.Description
                                </td>
                                <td class="px-4 py-4 text-sm text-right font-bold text-slate-900">
                                    @item.TotalPayment.ToString("N0") đ
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a href="#" class="p-1.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition-all" title="Xem chi tiết">
                                            <i data-lucide="eye" class="w-4 h-4"></i>
                                        </a>
                                        <a href="#" class="p-1.5 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-md transition-all" title="Chỉnh sửa">
                                            <i data-lucide="edit-3" class="w-4 h-4"></i>
                                        </a>
                                        <button type="button" class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-md transition-all" title="Xóa">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-100 flex justify-between items-center text-xs text-slate-500">
                <div>
                    Hiển thị <span class="font-bold text-slate-700">@Model.Count()</span> chứng từ
                </div>
                <div class="flex gap-2">
                    </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Khởi tạo Lucide Icons
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
    </script>
}