@model RevenueAccountingMVC.ViewModels.RevenueAdjustmentViewModel
@{
    ViewData["Title"] = "Ghi giảm doanh thu";
}

<div class="min-h-screen bg-slate-50 font-['Inter'] antialiased text-slate-900 pb-20">
    <form asp-action="Create" method="post" id="frmGhiGiam">
        <div class="sticky top-0 z-30 bg-white/80 backdrop-blur-md border-b border-slate-200 px-6 py-4 mb-8">
            <div class="max-w-7xl mx-auto d-flex justify-between items-center">
                <div class="flex items-center gap-4">
                    <a asp-action="Index" class="p-2 hover:bg-slate-100 rounded-full transition-colors">
                        <i data-lucide="arrow-left" class="w-5 h-5 text-slate-500"></i>
                    </a>
                    <div>
                        <h1 class="text-xl font-bold tracking-tight">Ghi giảm doanh thu</h1>
                        <p class="text-xs text-slate-500">Tạo mới chứng từ ghi giảm doanh thu</p>
                    </div>
                </div>
                <div class="flex gap-3">
                    <a asp-action="Index" class="px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-all">Hủy bỏ</a>
                    <button type="submit" name="actionType" value="Save" class="px-6 py-2 bg-slate-900 text-white text-sm font-semibold rounded-lg hover:bg-slate-800 shadow-sm transition-all flex items-center gap-2">
                        <i data-lucide="save" class="w-4 h-4"></i> Lưu chứng từ
                    </button>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 space-y-6">
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-sm font-bold uppercase tracking-wider text-slate-600 flex items-center gap-2">
                        <i data-lucide="info" class="w-4 h-4 text-indigo-500"></i> Thông tin chung
                    </h2>
                </div>
                <div class="p-6 grid grid-cols-1 md:grid-cols-4 gap-6">
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Số chứng từ</label>
                        <input asp-for="AdjustmentCode" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm font-bold text-indigo-600 outline-none" readonly />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Ngày chứng từ <span class="text-red-500">*</span></label>
                        <input asp-for="AdjustmentDate" type="date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Ngày hạch toán <span class="text-red-500">*</span></label>
                        <input asp-for="AccountingDate" type="date" class="w-full px-3 py-2 border border-indigo-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all bg-indigo-50/30" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Khách hàng</label>
                        <input asp-for="CustomerName" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-600" readonly id="txtCustomerName" placeholder="Tự động..." />
                        <input type="hidden" asp-for="CustomerId" id="hdnCustomerId" />
                    </div>
                    <div class="md:col-span-1 space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Mã khách hàng</label>
                        <input asp-for="CustomerCode" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm" readonly id="txtCustomerCode" />
                    </div>
                    <div class="md:col-span-3 space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Địa chỉ</label>
                        <input asp-for="Address" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm" readonly id="txtAddress" />
                    </div>
                    <div class="md:col-span-4 space-y-1">
                        <label class="text-xs font-semibold text-slate-500 uppercase">Diễn giải</label>
                        <textarea asp-for="Description" rows="2" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all" placeholder="Nhập lý do điều chỉnh..."></textarea>
                    </div>
                </div>
            </div>

            <div class="bg-indigo-50/50 rounded-xl border border-indigo-100 p-6 grid grid-cols-1 md:grid-cols-5 gap-6">
                <div class="space-y-1">
                    <label class="text-xs font-bold text-indigo-700 uppercase">Chứng từ bán hàng gốc</label>
                    <select asp-for="OriginalSalesVoucherId" asp-items="ViewBag.SalesVouchers" class="w-full px-3 py-2 bg-white border border-indigo-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500/20 outline-none shadow-sm" id="ddlOriginalVoucher">
                        <option value="">-- Chọn chứng từ --</option>
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase">Ngày bán</label>
                    <input type="date" asp-for="OriginalVoucherDate" class="w-full px-3 py-2 bg-transparent border-none text-sm text-slate-600 p-0" readonly id="txtOriginalDate" />
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase text-right block">Tiền hàng gốc</label>
                    <input type="number" asp-for="OriginalTotalAmount" class="w-full px-3 py-2 bg-transparent border-none text-sm text-slate-600 text-right font-medium" readonly id="txtOriginalAmount" />
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase text-right block">Tiền thuế gốc</label>
                    <input type="number" asp-for="OriginalTotalTax" class="w-full px-3 py-2 bg-transparent border-none text-sm text-slate-600 text-right font-medium" readonly id="txtOriginalTax" />
                </div>
                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-indigo-400 uppercase text-right block">Tổng thanh toán</label>
                    <input type="number" asp-for="OriginalTotalPayment" class="w-full px-3 py-2 bg-transparent border-none text-sm text-indigo-600 text-right font-bold" readonly id="txtOriginalPayment" />
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
                    <h2 class="text-sm font-bold uppercase tracking-wider text-slate-600 flex items-center gap-2">
                        <i data-lucide="list" class="w-4 h-4 text-indigo-500"></i> Chi tiết ghi giảm
                    </h2>
                    <button type="button" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1">
                        <i data-lucide="plus-circle" class="w-4 h-4"></i> Thêm dòng
                    </button>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse" id="tblDetails">
                        <thead>
                            <tr class="bg-slate-50/50 text-[10px] font-bold text-slate-500 uppercase tracking-widest border-b border-slate-100">
                                <th class="px-6 py-4 w-[18%]">Loại giảm</th>
                                <th class="px-4 py-4 w-[22%]">Sản phẩm</th>
                                <th class="px-4 py-4 text-center w-[10%]">Số lượng</th>
                                <th class="px-4 py-4 text-right w-[15%]">Đơn giá</th>
                                <th class="px-4 py-4 text-center w-[10%]">% CK</th>
                                <th class="px-4 py-4 text-right w-[15%]">Thành tiền</th>
                                <th class="px-6 py-4 text-center w-[10%]"></th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            </tbody>
                    </table>
                </div>
                
                <div class="p-6 bg-slate-50/30 border-t border-slate-100">
                    <div class="flex flex-col items-end space-y-3">
                        <div class="w-full md:w-80 space-y-2">
                            <div class="flex justify-between text-sm text-slate-500">
                                <span>Tổng tiền giảm:</span>
                                <span class="font-semibold text-slate-700" id="lblTotalAmount">0</span>
                                <input type="hidden" asp-for="TotalDiscountAmount" id="hdnTotalAmount" />
                            </div>
                            <div class="flex justify-between text-sm text-slate-500">
                                <span>Tổng thuế giảm:</span>
                                <span class="font-semibold text-slate-700" id="lblTotalTax">0</span>
                                <input type="hidden" asp-for="TotalTaxAmount" id="hdnTotalTax" />
                            </div>
                            <div class="pt-3 border-t border-slate-200 flex justify-between items-center">
                                <span class="text-base font-bold text-slate-900 uppercase">Tổng thanh toán:</span>
                                <span class="text-2xl font-black text-red-600" id="lblTotalPayment">0</span>
                                <input type="hidden" asp-for="TotalPayment" id="hdnTotalPayment" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4">
                <button type="submit" name="actionType" value="SaveAndNew" class="px-6 py-2.5 bg-white border border-slate-300 text-slate-700 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-all shadow-sm">Lưu và thêm mới</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // Khởi tạo Lucide Icons
            lucide.createIcons();
            
            // Cập nhật biến row trong JS để khớp với class Tailwind
            window.addRowToTable = function(item, index) {
                return `
                    <tr class="group hover:bg-slate-50/80 transition-colors">
                        <td class="px-6 py-4">
                            <select class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs focus:ring-2 focus:ring-indigo-500/20 outline-none ddl-type" name="Details[${index}].AdjustmentType" required>
                                <option value="">-- Chọn --</option>
                                <option value="TraLai">Hàng bán trả lại</option>
                                <option value="GiamGia">Giảm giá hàng bán</option>
                                <option value="ChietKhau">Chiết khấu thương mại</option>
                            </select>
                        </td>
                        <td class="px-4 py-4">
                            <input type="hidden" name="Details[${index}].ProductId" value="${item.productId}" />
                            <div class="text-xs font-semibold text-slate-700">${item.productName}</div>
                        </td>
                        <td class="px-4 py-4">
                            <input type="number" class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs text-center txt-qty disabled:bg-slate-50 disabled:text-slate-400" name="Details[${index}].Quantity" disabled required />
                            <input type="hidden" class="hdn-o-qty" value="${item.originalQty}" />
                        </td>
                        <td class="px-4 py-4">
                            <input type="number" class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs text-right txt-price disabled:bg-slate-50 disabled:text-slate-400" name="Details[${index}].UnitPrice" disabled required />
                            <input type="hidden" class="hdn-o-price" value="${item.originalPrice}" />
                        </td>
                        <td class="px-4 py-4">
                            <input type="number" class="w-full px-2 py-1.5 border border-slate-200 rounded-md text-xs text-center txt-discount disabled:bg-slate-50 disabled:text-slate-400" name="Details[${index}].DiscountRate" disabled />
                            <input type="hidden" class="hdn-tax-rate" value="${item.originalTaxRate}" />
                        </td>
                        <td class="px-4 py-4 text-right">
                            <input type="number" class="w-full bg-transparent border-none text-xs font-bold text-red-600 text-right outline-none txt-amount" name="Details[${index}].Amount" readonly />
                        </td>
                        <td class="px-6 py-4 text-center">
                            <button type="button" class="p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-md transition-all btn-delete">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </td>
                    </tr>`;
            };

            // Override lại hàm AJAX cũ để gọi addRowToTable mới
            $('#ddlOriginalVoucher').change(function () {
                let voucherId = $(this).val();
                if (!voucherId) return;

                $.get('/RevenueAdjustment/GetOriginalVoucher', { id: voucherId }, function (data) {
                    $('#hdnCustomerId').val(data.customerId);
                    $('#txtCustomerCode').val(data.customerCode);
                    $('#txtCustomerName').val(data.customerName);
                    $('#txtAddress').val(data.address);
                    $('#txtOriginalDate').val(data.voucherDate);
                    $('#txtOriginalAmount').val(data.totalAmount);
                    $('#txtOriginalTax').val(data.totalTax);
                    $('#txtOriginalPayment').val(data.totalPayment);

                    let tbody = $('#tblDetails tbody');
                    tbody.empty();
                    
                    if(data.details) {
                        data.details.forEach((item, index) => {
                            tbody.append(window.addRowToTable(item, index));
                        });
                        lucide.createIcons(); // Re-render icons cho dòng mới
                    }
                    CalculateTotal();
                });
            });

            // Gắn lại các hàm CalculateRow, CalculateTotal cũ của bạn vào đây...
        });
    </script>
}