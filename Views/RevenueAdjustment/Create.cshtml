@model RevenueAccountingMVC.ViewModels.RevenueAdjustmentViewModel
@{
    ViewData["Title"] = "Ghi giảm doanh thu";
}

<div class="min-h-screen bg-slate-50 font-['Inter'] antialiased text-slate-900 pb-20">
    <form asp-action="Create" method="post" id="frmGhiGiam">
        
        <div asp-validation-summary="ModelOnly" class="text-red-500 bg-red-100 p-4 mb-4 rounded mx-6 mt-4"></div>

        <div class="sticky top-0 z-30 bg-white border-b px-6 py-4 mb-8">
            <div class="flex justify-between items-center">
                <h1 class="text-xl font-bold">Ghi giảm doanh thu</h1>
                <div class="flex gap-3">
                    <a asp-action="Index" class="px-4 py-2 hover:bg-slate-100 rounded">Hủy</a>
                    <button type="submit" class="bg-black text-white px-4 py-2 rounded">Lưu chứng từ</button>
                </div>
            </div>
        </div>

        <div class="px-6 space-y-6">

            <div class="bg-white p-6 rounded shadow-sm">
                <h2 class="font-semibold text-lg mb-4">Thông tin chung</h2>
                <div class="grid grid-cols-4 gap-4">
                    <div>
                        <label class="block text-sm text-gray-500">Mã điều chỉnh</label>
                        <input asp-for="AdjustmentCode" class="w-full border rounded p-2 bg-gray-50" readonly />
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Ngày chứng từ</label>
                        <input asp-for="AdjustmentDate" type="date" class="w-full border rounded p-2" />
                    </div>
                    
                    <div>
                        <label class="block text-sm text-gray-500">Ngày hạch toán</label>
                        <input asp-for="AccountingDate" type="date" class="w-full border rounded p-2" />
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Khách hàng</label>
                        <select id="ddlCustomer" asp-for="CustomerId" asp-items="ViewBag.Customers" class="w-full border rounded p-2">
                            <option value="">-- Chọn khách hàng --</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Mã KH</label>
                        <input asp-for="CustomerCode" readonly id="txtCustomerCode" class="w-full border rounded p-2 bg-gray-50" />
                    </div>
                    
                    <div class="col-span-3">
                        <label class="block text-sm text-gray-500">Địa chỉ</label>
                        <input asp-for="Address" readonly id="txtAddress" class="w-full border rounded p-2 bg-gray-50" />
                    </div>

                    <div class="col-span-4">
                        <label class="block text-sm text-gray-500">Lý do điều chỉnh</label>
                        <textarea asp-for="Description" class="w-full border rounded p-2" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded shadow-sm">
                <h2 class="font-semibold text-lg mb-4">Tham chiếu chứng từ</h2>
                <div class="grid grid-cols-5 gap-4">
                    <div class="col-span-2">
                        <label class="block text-sm text-gray-500">Số chứng từ gốc</label>
                        <select asp-for="OriginalSalesVoucherId" id="ddlOriginalVoucher" asp-items="ViewBag.Vouchers" class="w-full border rounded p-2">
                            <option value="">-- Chọn chứng từ bán hàng --</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Ngày hóa đơn</label>
                        <input asp-for="OriginalVoucherDate" type="date" id="txtOriginalDate" class="w-full border rounded p-2 bg-gray-50" readonly />
                    </div>
                    
                    <div>
                        <label class="block text-sm text-gray-500">Tổng tiền gốc</label>
                        <input asp-for="OriginalTotalAmount" id="txtOriginalAmount" class="w-full border rounded p-2 bg-gray-50 text-right" readonly />
                    </div>
                    
                    <div>
                        <label class="block text-sm text-gray-500">Tổng thanh toán gốc</label>
                        <input asp-for="OriginalTotalPayment" id="txtOriginalPayment" class="w-full border rounded p-2 bg-gray-50 text-right" readonly />
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded shadow-sm">
                <h2 class="font-semibold text-lg mb-4">Chi tiết hàng hóa điều chỉnh</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse" id="tblDetails">
                        <thead>
                            <tr class="bg-slate-100 text-sm">
                                <th class="p-2 border">Loại điều chỉnh</th>
                                <th class="p-2 border">Sản phẩm</th>
                                <th class="p-2 border">SL Giảm/Trả</th>
                                <th class="p-2 border">Đơn giá giảm</th>
                                <th class="p-2 border">% CK</th>
                                <th class="p-2 border">Thành tiền (Âm)</th>
                                <th class="p-2 border text-center">Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Details != null && Model.Details.Any())
                            {
                                int i = 0;
                                foreach (var d in Model.Details)
                                {
                                    <tr>
                                        <input type="hidden" name="Details.Index" value="@i" />
                                        <td class="p-2 border">
                                            <select name="Details[@i].AdjustmentType" class="ddl-type w-full border p-1 rounded">
                                                <option value="" selected="@(d.AdjustmentType == "" ? "selected" : null)">--</option>
                                                <option value="GiamGia" selected="@(d.AdjustmentType == "GiamGia" ? "selected" : null)">Giảm giá</option>
                                                <option value="TraLai" selected="@(d.AdjustmentType == "TraLai" ? "selected" : null)">Trả lại</option>
                                                <option value="ChietKhau" selected="@(d.AdjustmentType == "ChietKhau" ? "selected" : null)">Chiết khấu</option>
                                            </select>
                                        </td>
                                        <td class="p-2 border">
                                            @d.ProductName
                                            <input type="hidden" name="Details[@i].ProductName" value="@d.ProductName" />
                                            <input type="hidden" name="Details[@i].ProductId" value="@d.ProductId" />
                                        </td>
                                        <td class="p-2 border"><input type="number" step="any" name="Details[@i].Quantity" class="txt-qty w-full border p-1 rounded text-right" value="@d.Quantity" /></td>
                                        <td class="p-2 border"><input type="number" step="any" name="Details[@i].UnitPrice" class="txt-price w-full border p-1 rounded text-right" value="@d.UnitPrice" /></td>
                                        <td class="p-2 border"><input type="number" step="any" name="Details[@i].DiscountRate" class="txt-discount w-full border p-1 rounded text-right" value="@d.DiscountRate" /></td>
                                        <td class="p-2 border"><input type="number" step="any" name="Details[@i].Amount" class="txt-amount w-full border p-1 rounded text-right bg-gray-50" value="@d.Amount" readonly /></td>
                                        <td class="p-2 border text-center"><button type="button" class="btn-delete text-red-500 font-bold hover:text-red-700">X</button></td>
                                        <input type="hidden" name="Details[@i].OriginalQty" class="hdn-o-qty" value="@d.OriginalQty" />
                                        <input type="hidden" name="Details[@i].OriginalPrice" class="hdn-o-price" value="@d.OriginalPrice" />
                                        <input type="hidden" name="Details[@i].OriginalTaxRate" class="hdn-tax-rate" value="@d.OriginalTaxRate" />
                                    </tr>
                                    i++;
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-6 border-t pt-4 flex flex-col items-end gap-2 text-sm">
                    <div class="flex w-64 justify-between">
                        <span class="font-semibold text-gray-600">Cộng tiền hàng (Giảm):</span>
                        <span id="lblTotalAmount" class="font-bold text-red-600">@Model.TotalDiscountAmount.ToString("N0")</span>
                    </div>
                    <div class="flex w-64 justify-between">
                        <span class="font-semibold text-gray-600">Tiền thuế (Giảm):</span>
                        <span id="lblTotalTax" class="font-bold text-red-600">@Model.TotalTaxAmount.ToString("N0")</span>
                    </div>
                    <div class="flex w-64 justify-between text-base">
                        <span class="font-bold">Tổng cộng:</span>
                        <span id="lblTotalPayment" class="font-bold text-red-600">@Model.TotalPayment.ToString("N0")</span>
                    </div>

                    <input type="hidden" asp-for="TotalDiscountAmount" id="hdnTotalAmount" />
                    <input type="hidden" asp-for="TotalTaxAmount" id="hdnTotalTax" />
                    <input type="hidden" asp-for="TotalPayment" id="hdnTotalPayment" />
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts{
<script>
let rowIdx = @(Model.Details?.Count ?? 0);

setTimeout(() => {
    $('#tblDetails tbody tr').each(function () {
        calculateRow($(this));
    });
}, 100);

// Hàm chỉ chạy khi Thay đổi "Loại điều chỉnh" -> Nhiệm vụ Khóa/Mở khóa UI
function updateRowUI(row) {
    let type = row.find('.ddl-type').val();
    let oQty = parseFloat(row.find('.hdn-o-qty').val()) || 0;
    let oPrice = parseFloat(row.find('.hdn-o-price').val()) || 0;

    // 1. Mặc định khóa tất cả và reset số về 0
    let inputs = row.find('.txt-qty, .txt-price, .txt-discount');
    inputs.prop('readonly', true).addClass('bg-gray-100').val(0);

    // 2. Mở khóa ô tương ứng theo Loại
    if (type === "TraLai") {
        row.find('.txt-qty').prop('readonly', false).removeClass('bg-gray-100').val(''); // Chờ người dùng nhập
        row.find('.txt-price').val(oPrice); 
    } else if (type === "GiamGia") {
        row.find('.txt-price').prop('readonly', false).removeClass('bg-gray-100').val(''); // Chờ người dùng nhập
        row.find('.txt-qty').val(oQty); 
    } else if (type === "ChietKhau") {
        row.find('.txt-discount').prop('readonly', false).removeClass('bg-gray-100').val(''); // Chờ người dùng nhập
        row.find('.txt-qty').val(oQty);
        row.find('.txt-price').val(oPrice);
    }

    calculateRow(row);
}

// Hàm chỉ chạy khi Đang gõ phím (input) -> Chỉ tính tiền, KHÔNG can thiệp readonly
function calculateRow(row){
    let type = row.find('.ddl-type').val();
    
    let qtyInput = row.find('.txt-qty').val();
    let priceInput = row.find('.txt-price').val();
    let discountInput = row.find('.txt-discount').val();

    let qty = parseFloat(qtyInput) || 0;
    let price = parseFloat(priceInput) || 0;
    let discount = parseFloat(discountInput) || 0;

    let oQty = parseFloat(row.find('.hdn-o-qty').val()) || 0;
    let oPrice = parseFloat(row.find('.hdn-o-price').val()) || 0;

    if (!type) {
        row.find('.txt-amount').val(0);
        return;
    }

    if (type === "TraLai") {
        if (qty > oQty) {
            alert("Số lượng trả lại không được vượt quá số lượng mua (" + oQty + ")!");
            qty = oQty;
            row.find('.txt-qty').val(qty);
        }
        amount = -(qty * oPrice);
    } else if (type === "GiamGia") {
        if (price > oPrice) {
            alert("Đơn giá giảm không được vượt quá đơn giá gốc (" + oPrice + ")!");
            price = oPrice;
            row.find('.txt-price').val(price);
        }
        amount = -(oQty * price);
    } else if (type === "ChietKhau") {
        if (discount > 100 || discount < 0) {
            alert("Tỷ lệ chiết khấu không hợp lệ!");
            discount = 0;
            row.find('.txt-discount').val(discount);
        }
        amount = -(oQty * oPrice * discount / 100);
    }

    row.find('.txt-amount').val(amount.toFixed(2));
    calculateTotal();
}

function calculateTotal(){
    let total = 0;
    let tax = 0;

    $('#tblDetails tbody tr').each(function(){
        let amt = parseFloat($(this).find('.txt-amount').val()) || 0;
        let rate = parseFloat($(this).find('.hdn-tax-rate').val()) || 0;

        total += amt;
        tax += amt * rate / 100;
    });

    let payment = total + tax;

    $('#lblTotalAmount').text(total.toLocaleString('vi-VN'));
    $('#lblTotalTax').text(tax.toLocaleString('vi-VN'));
    $('#lblTotalPayment').text(payment.toLocaleString('vi-VN'));

    $('#hdnTotalAmount').val(total);
    $('#hdnTotalTax').val(tax);
    $('#hdnTotalPayment').val(payment);
}

// Bắt sự kiện thay đổi loại (Chạy hàm Reset UI)
$(document).on('change','.ddl-type',function(){
    updateRowUI($(this).closest('tr'));
});

// Bắt sự kiện gõ phím (Chạy hàm Tính toán)
$(document).on('input','.txt-qty, .txt-price, .txt-discount',function(){
    calculateRow($(this).closest('tr'));
});

$(document).on('click','.btn-delete',function(){
    $(this).closest('tr').remove();
    calculateTotal();
});

// ===== LOAD VOUCHERS =====
$('#ddlCustomer').change(function(){
    let id = $(this).val();

    $('#ddlOriginalVoucher').empty().append('<option value="">-- Chọn chứng từ --</option>');

    if(id){
        $.get(`/RevenueAdjustment/GetVouchersByCustomer?customerId=${id}`,function(res){
            res.forEach(v=>{
                $('#ddlOriginalVoucher').append(`<option value="${v.id}">${v.voucherCode}</option>`);
            });
        });
    }
});

// ===== LOAD DETAILS =====
$('#ddlOriginalVoucher').change(function(){
    let id = $(this).val();

    if(id){
        $.get(`/RevenueAdjustment/GetOriginalVoucher/${id}`,function(res){

            $('#txtCustomerCode').val(res.customerCode);
            $('#txtAddress').val(res.address);

            $('#txtOriginalDate').val(res.voucherDate);
            $('#txtOriginalAmount').val(res.totalAmount.toLocaleString('vi-VN'));
            $('#txtOriginalPayment').val(res.totalPayment.toLocaleString('vi-VN'));

            let tbody = $('#tblDetails tbody');
            tbody.empty();
            rowIdx = 0; // Reset index cho hóa đơn mới

            res.details.forEach(d=>{
                let row = `
                <tr>
                    <input type="hidden" name="Details.Index" value="${rowIdx}" />
                    
                    <td class="p-2 border">
                        <select name="Details[${rowIdx}].AdjustmentType" class="ddl-type w-full border p-1 rounded">
                            <option value="">--</option>
                            <option value="GiamGia">Giảm giá</option>
                            <option value="TraLai">Trả lại</option>
                            <option value="ChietKhau">Chiết khấu</option>
                        </select>
                    </td>

                    <td class="p-2 border">
                        ${d.productName}
                        <input type="hidden" name="Details[${rowIdx}].ProductName" value="${d.productName}" />
                        <input type="hidden" name="Details[${rowIdx}].ProductId" value="${d.productId}" />
                    </td>

                    <td class="p-2 border">
                        <input type="number" step="any" name="Details[${rowIdx}].Quantity" class="txt-qty w-full border p-1 rounded text-right bg-gray-100" value="0" readonly />
                    </td>

                    <td class="p-2 border">
                        <input type="number" step="any" name="Details[${rowIdx}].UnitPrice" class="txt-price w-full border p-1 rounded text-right bg-gray-100" value="0" readonly />
                    </td>

                    <td class="p-2 border">
                        <input type="number" step="any" name="Details[${rowIdx}].DiscountRate" class="txt-discount w-full border p-1 rounded text-right bg-gray-100" value="0" readonly />
                    </td>

                    <td class="p-2 border">
                        <input type="number" step="any" name="Details[${rowIdx}].Amount" class="txt-amount w-full border p-1 rounded text-right bg-gray-100" value="0" readonly />
                    </td>

                    <td class="p-2 border text-center">
                        <button type="button" class="btn-delete text-red-500 font-bold hover:text-red-700">X</button>
                    </td>

                    <input type="hidden" name="Details[${rowIdx}].OriginalQty" class="hdn-o-qty" value="${d.originalQty}" />
                    <input type="hidden" name="Details[${rowIdx}].OriginalPrice" class="hdn-o-price" value="${d.originalPrice}" />
                    <input type="hidden" name="Details[${rowIdx}].OriginalTaxRate" class="hdn-tax-rate" value="${d.originalTaxRate}" />
                </tr>
                `;
                tbody.append(row);
                rowIdx++;
            });
            calculateTotal(); 
        });
    }
});

// Chạy lại UI khi trang bị load lại (Submit lỗi ModelState)
$(document).ready(function() {
    if ($('#tblDetails tbody tr').length > 0) {
        $('#tblDetails tbody tr').each(function() {
            let row = $(this);
            let type = row.find('.ddl-type').val();
            
            // Thiết lập trạng thái khóa/mở nhưng KHÔNG ghi đè giá trị bạn đã nhập trướ đó
            row.find('.txt-qty, .txt-price, .txt-discount').prop('readonly', true).addClass('bg-gray-100');
            
            if (type === "TraLai") {
                row.find('.txt-qty').prop('readonly', false).removeClass('bg-gray-100');
            } else if (type === "GiamGia") {
                row.find('.txt-price').prop('readonly', false).removeClass('bg-gray-100');
            } else if (type === "ChietKhau") {
                row.find('.txt-discount').prop('readonly', false).removeClass('bg-gray-100');
            }
            
            calculateRow(row);
        });
    }
});

// FIX: scroll lên khi lỗi
$(document).ready(function () {
    if ($('.validation-summary-errors').length) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
});
</script>
}