@model RevenueAccountingMVC.ViewModels.RevenueAdjustmentViewModel
@{
    ViewData["Title"] = "Ghi giảm doanh thu";
}
@if (TempData["Error"] != null)
{
    <div class="text-red-500">@TempData["Error"]</div>
}

<div class="min-h-screen bg-slate-50 font-['Inter'] antialiased text-slate-900 pb-20">
    <form asp-action="Create" method="post" id="frmGhiGiam">
        
        <!-- 1. SỬA LỖI HIỂN THỊ KHUNG ĐỎ: Chỉ hiển thị khi có lỗi thật -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="text-red-700 bg-red-100 border border-red-400 p-4 mb-4 rounded-lg font-medium"></div>
        }

        <div class="sticky top-0 z-30 bg-white border-b px-6 py-4 mb-8">
            <div class="flex justify-between items-center">
                <h1 class="text-xl font-bold">Ghi giảm doanh thu</h1>
                <div class="flex gap-3">
                    <a asp-action="Index" class="px-4 py-2 hover:bg-slate-100 rounded">Hủy</a>
                    <button type="submit" class="bg-black text-white px-4 py-2 rounded">Lưu chứng từ</button>
                </div>
            </div>
        </div>

        <div class="px-6 space-y-6">

            <div class="bg-white p-6 rounded shadow-sm">
                <h2 class="font-semibold text-lg mb-4">Thông tin chung</h2>
                <div class="grid grid-cols-4 gap-4">
                    <div>
                        <label class="block text-sm text-gray-500">Mã điều chỉnh</label>
                        <input asp-for="AdjustmentCode" class="w-full border rounded p-2 bg-gray-50" readonly />
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Ngày chứng từ</label>
                        <input asp-for="AdjustmentDate" type="date" class="w-full border rounded p-2" />
                    </div>
                    
                    <div>
                        <label class="block text-sm text-gray-500">Ngày hạch toán</label>
                        <input asp-for="AccountingDate" type="date" class="w-full border rounded p-2" />
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Khách hàng</label>
                        <select id="ddlCustomer" asp-for="CustomerId" asp-items="ViewBag.Customers" class="w-full border rounded p-2">
                            <option value="">-- Chọn khách hàng --</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm text-gray-500">Mã KH</label>
                        <input asp-for="CustomerCode" readonly id="txtCustomerCode" class="w-full border rounded p-2 bg-gray-50" />
                    </div>
                    
                    <div class="col-span-3">
                        <label class="block text-sm text-gray-500">Địa chỉ</label>
                        <input asp-for="Address" readonly id="txtAddress" class="w-full border rounded p-2 bg-gray-50" />
                    </div>

                    <div class="col-span-4">
                        <label class="block text-sm text-gray-500">Lý do điều chỉnh</label>
                        <textarea asp-for="Description" class="w-full border rounded p-2" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h2 class="font-bold text-[16px] text-gray-900 mb-5">Chứng từ gốc</h2>
                
                <div class="grid grid-cols-3 gap-6">
                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Số chứng từ bán hàng</label>
                        <select asp-for="OriginalSalesVoucherId" id="ddlOriginalVoucher" asp-items="ViewBag.Vouchers" class="w-full bg-[#f8fafc] border border-transparent focus:border-blue-500 rounded-lg p-2.5 text-[14px] outline-none transition-colors">
                            <option value="">-- Chọn --</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Ngày chứng từ</label>
                        <input asp-for="OriginalVoucherDate" type="date" id="txtOriginalDate" class="w-full bg-[#f8fafc] border border-transparent rounded-lg p-2.5 text-[14px] text-gray-600 outline-none pointer-events-none" readonly />
                    </div>

                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Khách hàng</label>
                        <input type="text" id="txtOriginalCustomer" class="w-full bg-[#f8fafc] border border-transparent rounded-lg p-2.5 text-[14px] text-gray-600 outline-none pointer-events-none" readonly />
                    </div>

                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Tổng tiền hàng</label>
                        <input type="hidden" asp-for="OriginalTotalAmount" id="hdnOriginalAmount" />

                        <input type="text"
                            id="txtOriginalAmountDisplay"
                            class="w-full bg-[#f8fafc] border border-gray-200 rounded-lg p-2.5 text-[14px] text-gray-600"
                            readonly />
                    </div>

                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Thuế GTGT (%)</label>
                        <input type="hidden" asp-for="OriginalTotalTax" id="hdnOriginalTax" />

                        <input type="text"
                            id="txtOriginalTaxRateDisplay"
                            class="w-full bg-[#f8fafc] border border-gray-200 rounded-lg p-2.5 text-[14px] text-gray-600"
                            readonly />
                    </div>
                    
                    <div>
                        <label class="block text-[13px] font-medium text-gray-700 mb-1.5">Tổng thanh toán</label>
                        <input type="hidden" asp-for="OriginalTotalPayment" id="hdnOriginalPayment" />

                        <input type="text"
                            id="txtOriginalPaymentDisplay"
                            class="w-full bg-[#f8fafc] border border-gray-200 rounded-lg p-2.5 text-[14px] text-gray-600"
                            readonly />
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 pb-0">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="font-bold text-[16px] text-gray-900">Chi tiết ghi giảm</h2>
                        <button type="button" id="btnAddRow" class="text-blue-600 text-[14px] font-medium flex items-center gap-1.5 hover:text-blue-700 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                            Thêm dòng
                        </button>
                    </div>

                    <div class="flex gap-6 border-b border-gray-200">
                        <button type="button" id="btnTabRevenue" class="pb-3 text-[14px] font-semibold text-blue-600 border-b-2 border-blue-600 transition-colors">Ghi giảm doanh thu</button>
                        <button type="button" id="btnTabTax" class="pb-3 text-[14px] font-semibold text-gray-500 border-b-2 border-transparent hover:text-gray-800 transition-colors">Hạch toán thuế</button>
                    </div>
                </div>

                <div class="p-6 overflow-x-auto">
                    <div id="tabRevenueContent" class="block">
                        <table class="w-full text-left text-[13px]" id="tblDetails">
                            <thead class="text-gray-500 font-medium border-b border-gray-100">
                                <tr>
                                    <th class="pb-3 px-2 w-[220px]">SẢN PHẨM</th>
                                    <th class="pb-3 px-2 w-[100px]">SỐ LƯỢNG</th>
                                    <th class="pb-3 px-2 w-[120px]">ĐƠN GIÁ</th>
                                    <th class="pb-3 px-2 w-[100px]">TK NỢ</th>
                                    <th class="pb-3 px-2 w-[100px]">TK CÓ</th>
                                    <th class="pb-3 px-2 w-[80px]">%CK</th>
                                    <th class="pb-3 px-2 w-[130px]">THÀNH TIỀN</th>
                                    <th class="pb-3 px-2 w-[180px]">LOẠI GIẢM</th>
                                    <th class="pb-3 px-2 text-center w-[50px]"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                            </tbody>
                        </table>
                    </div>

                    <div id="tabTaxContent" class="hidden">
                        <table class="w-full text-left text-[13px]" id="tblTaxDetails">
                            <thead class="text-gray-500 font-medium border-b border-gray-100">
                                <tr>
                                    <th class="pb-3 px-2 w-[150px]">THUẾ SUẤT (%)</th>
                                    <th class="pb-3 px-2 w-[200px]">THÀNH TIỀN (Nhập số âm)</th>
                                    <th class="pb-3 px-2 w-[150px]">TK THUẾ</th>
                                    <th class="pb-3 px-2"></th>
                                    <th class="pb-3 px-2 text-center w-[50px]"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="px-6 py-5 bg-gray-50 flex flex-col items-end gap-2 text-[14px]">
                    <div class="flex w-[300px] justify-between">
                        <span class="font-medium text-gray-600">Cộng tiền hàng (Giảm):</span>
                        <span id="lblTotalAmount" class="font-bold text-gray-900">@Model.TotalDiscountAmount.ToString("N0")</span>
                    </div>
                    <div class="flex w-[300px] justify-between">
                        <span class="font-medium text-gray-600">Tiền thuế (Giảm):</span>
                        <span id="lblTotalTax" class="font-bold text-gray-900">@Model.TotalTaxAmount.ToString("N0")</span>
                    </div>
                    <div class="flex w-[300px] justify-between text-[16px] mt-2 pt-2 border-t border-gray-200">
                        <span class="font-bold text-gray-900">Tổng cộng:</span>
                        <span id="lblTotalPayment" class="font-bold text-blue-600">@Model.TotalPayment.ToString("N0")</span>
                    </div>

                    <input type="hidden" asp-for="TotalDiscountAmount" id="hdnTotalAmount" />
                    <input type="hidden" asp-for="TotalTaxAmount" id="hdnTotalTax" />
                    <input type="hidden" asp-for="TotalPayment" id="hdnTotalPayment" />
                    
                    <input type="hidden" id="hdnTaxDetailsCount" value="0" />
                </div>
            </div>

        </div>
    </form>
</div>

<template id="tpl-accounts">
    @if(ViewBag.Accounts != null)
    {
        @foreach (var item in (SelectList)ViewBag.Accounts) 
        { 
            <option value="@item.Value">@item.Text</option> 
        }
    }
</template>

@section Scripts{
<script>
$('#btnTabRevenue').click(function() {
    $(this).removeClass('text-gray-500 border-transparent').addClass('text-blue-600 border-blue-600');
    $('#btnTabTax').removeClass('text-blue-600 border-blue-600').addClass('text-gray-500 border-transparent');
    $('#tabRevenueContent').removeClass('hidden').addClass('block');
    $('#tabTaxContent').removeClass('block').addClass('hidden');
});

$('#btnTabTax').click(function() {
    $(this).removeClass('text-gray-500 border-transparent').addClass('text-blue-600 border-blue-600');
    $('#btnTabRevenue').removeClass('text-blue-600 border-blue-600').addClass('text-gray-500 border-transparent');
    $('#tabTaxContent').removeClass('hidden').addClass('block');
    $('#tabRevenueContent').removeClass('block').addClass('hidden');
    
    // Cập nhật lại tax amount cho tất cả các dòng
    updateAllTaxAmounts();
});

// SỬA: Hàm updateAllTax không đè lên nếu người dùng đã tự sửa
function updateAllTaxAmounts() {
    $('#tblDetails tbody tr:not(.tax-row)').each(function() {
        let row = $(this);
        let amount = parseFloat(row.find('.txt-amount').val()) || 0;
        let index = row.find('input[name$=".Index"]').val();
        let taxRate = parseFloat(row.find('.hdn-tax-rate').val()) || 0;
        
        let taxRow = $(`.tax-row[data-ref="${index}"]`);
        
        // NẾU dòng chưa bị chỉnh tay -> tự động tính lại
        if(taxRow.length > 0 && !taxRow.data('manual')) {
            let taxAmount = amount * (taxRate / 100);
            taxRow.find('.txt-tax-amount').val(taxAmount.toFixed(0));
        }
    });
    calculateTotal();
}

function safeNumber(val) {
    return (val === null || val === undefined || val === "") ? 0 : val;
}

$('#ddlOriginalVoucher').change(function(){
    let id = $(this).val();

    if(id){
        $.get(`/RevenueAdjustment/GetOriginalVoucher/${id}`,function(res){
            const accountsOptionsHtml = $('#tpl-accounts').html();

            $('#txtCustomerCode').val(res.customerCode);
            $('#txtOriginalCustomer').val(res.customerName); 
            $('#txtAddress').val(res.address);
            $('#txtOriginalDate').val(res.voucherDate);

            $('#txtOriginalAmountDisplay').val((res.totalAmount || 0).toLocaleString('vi-VN') + ' đ');
            $('#txtOriginalTaxRateDisplay').val((res.taxRate || 0) + ' %');
            $('#txtOriginalPaymentDisplay').val((res.totalPayment || 0).toLocaleString('vi-VN') + ' đ');

            $('#hdnOriginalAmount').val(safeNumber(res.totalAmount));
            $('#hdnOriginalTax').val(safeNumber(res.totalTaxAmount));
            $('#hdnOriginalPayment').val(safeNumber(res.totalPayment));

            let tbodyRevenue = $('#tblDetails tbody');
            tbodyRevenue.empty();

            let tbodyTax = $('#tblTaxDetails tbody');
            tbodyTax.empty();

            rowIdx = 0;

            res.details.forEach(d => {
                let row = `
                <tr class="group">
                    <input type="hidden" name="Details.Index" value="${rowIdx}" />

                    <!-- HIỂN THỊ LUÔN TÊN VÀ SỐ LƯỢNG GỐC -->
                    <td class="py-2 px-2">
                        <input type="text" class="w-full border border-gray-200 rounded p-1.5 bg-[#f8fafc] text-xs font-semibold" 
                               value="${d.productCode} - Tồn: ${d.originalQty}" readonly title="${d.productName}" />
                        <input type="hidden" name="Details[${rowIdx}].ProductId" value="${d.productId}" />
                    </td>

                    <td class="py-2 px-2">
                        <input type="number" name="Details[${rowIdx}].Quantity" class="txt-qty w-full border border-gray-200 rounded p-1.5" value="0" readonly />
                    </td>

                    <td class="py-2 px-2">
                        <input type="number" name="Details[${rowIdx}].UnitPrice" class="txt-price w-full border border-gray-200 rounded p-1.5" value="0" readonly />
                    </td>

                    <td class="py-2 px-2">
                        <select class="w-full border border-gray-200 rounded p-1.5" name="Details[${rowIdx}].DebitAccountId">
                            <option value="">-- Chọn --</option>
                            ${accountsOptionsHtml}
                        </select>
                    </td>

                    <td class="py-2 px-2">
                        <select class="w-full border border-gray-200 rounded p-1.5" name="Details[${rowIdx}].CreditAccountId">
                            <option value="">-- Chọn --</option>
                            ${accountsOptionsHtml}
                        </select>
                    </td>

                    <td class="py-2 px-2">
                        <input type="number" step="0.01" class="txt-discount w-full border border-gray-200 rounded p-1.5" name="Details[${rowIdx}].DiscountRate" value="0" />
                    </td>

                    <td class="py-2 px-2">
                        <input type="text" name="Details[${rowIdx}].Amount" class="txt-amount w-full border border-transparent bg-transparent text-right font-semibold" value="0" readonly />
                    </td>

                    <td class="py-2 px-2">
                        <select name="Details[${rowIdx}].AdjustmentType" class="ddl-type w-full border border-gray-200 rounded p-1.5">
                            <option value="">-- Chọn loại --</option>
                            <option value="GiamGia">Giảm giá hàng bán</option>
                            <option value="TraLai">Hàng bán bị trả lại</option>
                            <option value="ChietKhau">Chiết khấu TM</option>
                        </select>
                    </td>

                    <td class="py-2 px-2 text-center">
                        <button type="button" class="btn-delete text-red-500 font-bold">X</button>
                    </td>

                    <!-- SỬA LỖI QUAN TRỌNG: Thêm class hdn-o-qty và hdn-o-price để JS đọc được gốc -->
                    <input type="hidden" name="Details[${rowIdx}].OriginalQty" class="hdn-o-qty" value="${d.originalQty}" />
                    <input type="hidden" name="Details[${rowIdx}].OriginalPrice" class="hdn-o-price" value="${d.originalPrice}" />
                    <input type="hidden" name="Details[${rowIdx}].OriginalTaxRate" class="hdn-tax-rate" value="${d.originalTaxRate}" />
                </tr>
                `;

                tbodyRevenue.append(row);

                // TAX
                if (d.originalTaxRate > 0) {
                    let taxRow = `
                    <tr class="tax-row" data-ref="${rowIdx}">
                        <input type="hidden" name="TaxDetails.Index" value="${rowIdx}" />

                        <td class="py-2 px-2 font-semibold">
                            VAT ${d.originalTaxRate}%
                            <input type="hidden" name="TaxDetails[${rowIdx}].TaxRate" value="${d.originalTaxRate}" />
                        </td>

                        <!-- SỬA LỖI: Sửa ô hiển thị thuế thành input cho phép tự sửa nhập liệu -->
                        <td class="py-2 px-2">
                            <input type="number" step="any" name="TaxDetails[${rowIdx}].TaxAmount" class="txt-tax-amount w-full border border-gray-300 rounded p-1.5 focus:border-blue-500 focus:ring-1 focus:ring-blue-500" value="0" />
                        </td>

                        <td class="py-2 px-2">
                            <select class="w-full border border-gray-200 rounded p-1.5" name="TaxDetails[${rowIdx}].TaxAccountId">
                                <option value="">-- Chọn --</option>
                                ${accountsOptionsHtml}
                            </select>
                        </td>

                        <td></td>
                        <td class="text-center"></td>
                    </tr>
                    `;

                    tbodyTax.append(taxRow);
                }

                rowIdx++;
            });

            calculateTotal();
        });
    } else {
        $('#txtOriginalAmountDisplay,#txtOriginalTaxRateDisplay,#txtOriginalPaymentDisplay').val('');
        $('#hdnOriginalAmount,#hdnOriginalTax,#hdnOriginalPayment').val(0);
    }
});

let rowIdx = @(Model.Details?.Count ?? 0);

setTimeout(() => {
    $('#tblDetails tbody tr:not(.tax-row)').each(function () {
        calculateRow($(this));
    });
}, 100);

function updateRowUI(row) {
    let type = row.find('.ddl-type').val();
    let oQty = parseFloat(row.find('.hdn-o-qty').val()) || 0;
    let oPrice = parseFloat(row.find('.hdn-o-price').val()) || 0;

    let inputs = row.find('.txt-qty, .txt-price, .txt-discount');
    inputs.prop('readonly', true).removeClass('bg-white').addClass('bg-[#f8fafc]').val('');

    if (type === "TraLai") {
        row.find('.txt-qty').prop('readonly', false).removeClass('bg-[#f8fafc]').addClass('bg-white border-blue-300'); 
        row.find('.txt-price').val(oPrice); 
    } else if (type === "GiamGia") {
        row.find('.txt-price').prop('readonly', false).removeClass('bg-[#f8fafc]').addClass('bg-white border-blue-300'); 
        row.find('.txt-qty').val(oQty); 
    } else if (type === "ChietKhau") {
        row.find('.txt-discount').prop('readonly', false).removeClass('bg-[#f8fafc]').addClass('bg-white border-blue-300'); 
        row.find('.txt-qty').val(oQty);
        row.find('.txt-price').val(oPrice);
    }

    calculateRow(row);
}

function calculateRow(row){
    let type = row.find('.ddl-type').val();
    if (!type) {
        row.find('.txt-amount').val(0);
        updateTaxTab(row, 0);
        return;
    }

    let qty = parseFloat(row.find('.txt-qty').val()) || 0;
    let price = parseFloat(row.find('.txt-price').val()) || 0;
    let discount = parseFloat(row.find('.txt-discount').val()) || 0;

    let oQty = parseFloat(row.find('.hdn-o-qty').val()) || 0;
    let oPrice = parseFloat(row.find('.hdn-o-price').val()) || 0;
    let amount = 0;

    if (type === "TraLai") {
        if (qty > 0) {
            qty = -qty;
            row.find('.txt-qty').val(qty);
        }
        if (Math.abs(qty) > oQty) {
            // Sửa lại câu alert này
            alert("Số lượng trả lại không được vượt quá số lượng còn lại (" + oQty + ")!");
            qty = -oQty;
            row.find('.txt-qty').val(qty);
        }
        amount = qty * oPrice; 
    } 
    else if (type === "GiamGia") {
        if (price > 0) {
            price = -price;
            row.find('.txt-price').val(price);
        }
        if (Math.abs(price) > oPrice) {
            // Sửa lại câu alert này
            alert("Đơn giá giảm không được vượt quá giá trị có thể giảm (" + oPrice + ")!");
            price = -oPrice;
            row.find('.txt-price').val(price);
        }
        amount = oQty * price; 
    }
    else if (type === "ChietKhau") {
        if (discount < 0 || discount > 100) {
            alert("Tỷ lệ chiết khấu phải từ 0 đến 100!");
            discount = 0;
            row.find('.txt-discount').val(discount);
        }
        amount = -(oQty * oPrice * (discount / 100)); 
    }

    row.find('.txt-amount').val(amount.toFixed(0));
    updateTaxTab(row, amount);
    calculateTotal();
}

// Hàm update Tax đã được tinh chỉnh cho ô nhập liệu tự do
function updateTaxTab(row, amount) {
    let index = row.find('input[name$=".Index"]').val();
    let taxRate = parseFloat(row.find('.hdn-tax-rate').val()) || 0;

    let taxRow = $(`.tax-row[data-ref="${index}"]`);
    if (taxRow.length === 0) return;

    if (!taxRow.data('manual')) {
        let taxAmount = amount * (taxRate / 100);
        taxRow.find('.txt-tax-amount').val(taxAmount.toFixed(0));
    }
}

function calculateTotal(){
    let total = 0;
    let tax = 0;

    $('#tblDetails tbody tr:not(.tax-row)').each(function(){
        let amt = parseFloat($(this).find('.txt-amount').val()) || 0;
        total += amt;
    });

    $('#tblTaxDetails tbody tr').each(function(){
        let t = parseFloat($(this).find('.txt-tax-amount').val()) || 0;
        tax += t;
    });

    let payment = total + tax;

    $('#lblTotalAmount').text(total.toLocaleString('vi-VN'));
    $('#lblTotalTax').text(tax.toLocaleString('vi-VN'));
    $('#lblTotalPayment').text(payment.toLocaleString('vi-VN'));

    $('#hdnTotalAmount').val(total);
    $('#hdnTotalTax').val(tax);
    $('#hdnTotalPayment').val(payment);
}

$(document).on('change', '.ddl-type', function(){
    updateRowUI($(this).closest('tr'));
});

$(document).on('change', '.txt-qty, .txt-price, .txt-discount', function(){
    calculateRow($(this).closest('tr'));
});

// Sự kiện mới: Đánh dấu đã sửa tay khi gõ vào ô Thuế
$(document).on('change', '.txt-tax-amount', function(){
    $(this).closest('.tax-row').data('manual', true);
    calculateTotal();
});

$(document).on('click', '.btn-delete', function(){
    let row = $(this).closest('tr');
    let index = row.find('input[name$=".Index"]').val();
    
    row.remove(); 
    $(`.tax-row[data-ref="${index}"]`).remove();
    
    reindexAdjustmentRows();
    calculateTotal();
});

function reindexAdjustmentRows() {
    $('#tblDetails tbody tr:not(.tax-row)').each(function(i) {
        const row = $(this);
        const oldIndex = row.find('input[name="Details.Index"]').val();

        row.find('input[name="Details.Index"]').val(i);
        row.find('[name^="Details["]').each(function() {
            const current = $(this).attr('name');
            $(this).attr('name', current.replace(/Details\[\d+\]/, `Details[${i}]`));
        });

        const taxRow = $(`.tax-row[data-ref="${oldIndex}"]`);

        if (taxRow.length > 0) {
            taxRow.attr('data-ref', i);
            taxRow.find('input[name="TaxDetails.Index"]').val(i);
            taxRow.find('[name^="TaxDetails["]').each(function() {
                const current = $(this).attr('name');
                $(this).attr('name', current.replace(/TaxDetails\[\d+\]/, `TaxDetails[${i}]`));
            });
            taxRow.find('input[name$=".RefIndex"]').val(i);
        }
    });
}

$('#ddlCustomer').change(function(){
    let id = $(this).val();
    $('#ddlOriginalVoucher').empty().append('<option value="">-- Chọn chứng từ --</option>');
    if(id){
        $.get(`/RevenueAdjustment/GetVouchersByCustomer?customerId=${id}`,function(res){
            res.forEach(v=>{
                $('#ddlOriginalVoucher').append(`<option value="${v.id}">${v.voucherCode}</option>`);
            });
        });
    }
});

$(document).ready(function () {
    if ($('#tblDetails tbody tr:not(.tax-row)').length > 0) {
        $('#tblDetails tbody tr:not(.tax-row)').each(function () {
            updateRowUI($(this));
        });
    }

    if ($('.validation-summary-errors').length) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    $('#frmGhiGiam').on('submit', function () {
        reindexAdjustmentRows();
    });
});
</script>
