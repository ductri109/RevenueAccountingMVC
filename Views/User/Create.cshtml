@model RevenueAccountingMVC.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Thêm người dùng mới";
}

<div class="min-h-screen bg-slate-50 p-6 flex justify-center">
    <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-200 w-full max-w-lg mt-10 h-fit">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">Thêm người dùng mới</h2>

        <form asp-action="Create" method="post">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-4 border border-red-200" asp-validation-summary="All"></div>
            }

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Họ và tên</label>
                    <input asp-for="FullName" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="Nguyễn Văn A" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email đăng nhập</label>
                    <input asp-for="Email" type="email" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="email@congty.com" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
                    <input asp-for="Password" type="password" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" placeholder="••••••••" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phân quyền</label>
                    <select asp-for="Role" class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-blue-500">
                        <option value="2">Kế toán</option>
                        <option value="3">Lãnh đạo</option>
                        <option value="1">Quản trị viên (Admin)</option>
                    </select>
                </div>
            </div>

            <div class="mt-8 flex gap-3">
                <a asp-action="Index" class="w-1/3 text-center py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 font-medium">Hủy</a>
                <button type="submit" class="w-2/3 py-2.5 bg-black hover:bg-gray-700 text-white rounded-lg font-medium transition-colors">Tạo tài khoản</button>
            </div>
        </form>
    </div>
</div>