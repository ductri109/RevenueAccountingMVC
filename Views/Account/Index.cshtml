@using RevenueAccountingMVC.Models
@model IEnumerable<Account>

@{
    ViewData["Title"] = "Quản lý danh mục tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["ActiveTab"] = "Account";
    
    // Khởi tạo các biến phân trang từ Controller truyền sang
    int currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    int totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    int totalItems = ViewData["TotalItems"] != null ? (int)ViewData["TotalItems"] : 0;
    string currentSearch = ViewData["CurrentSearch"]?.ToString();

    // Truyền tổng số bản ghi vào Tab
    ViewData["CurrentCount"] = totalItems;

    // Hàm đệ quy tính cấp độ tài khoản
    int GetAccountLevel(Account account)
    {
        int level = 1;
        var parent = account.ParentAccount;
        while (parent != null)
        {
            level++;
            parent = parent.ParentAccount;
        }
        return level;
    }
}

<div class="p-8">
    <div>
        <h2 class="text-[22px] font-bold text-gray-900">Quản lý danh mục</h2>
        <p class="text-[14px] text-gray-500 mt-1">Quản lý dữ liệu danh mục hệ thống</p>
    </div>

    <partial name="_CategoryTabs" />

    @* --- THANH CÔNG CỤ --- *@
    <div class="mt-6 bg-white border border-gray-200 rounded-xl p-3 flex items-center gap-3 shadow-sm">
        <a asp-action="Create" class="bg-[#0f172a] hover:bg-gray-800 text-white px-4 py-2.5 rounded-lg text-[14px] font-medium inline-flex items-center gap-2 transition-colors active:scale-95">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm mới
        </a>

        <form asp-action="Index" method="get" class="flex items-center gap-3 flex-1">
            <div class="relative w-[360px]">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
                </div>
                <!-- Input tìm kiếm (Khi submit form mặc định sẽ về lại trang 1) -->
                <input type="text" name="searchString" value="@currentSearch" class="w-full bg-gray-50 border border-transparent focus:bg-white focus:border-gray-300 rounded-lg pl-9 pr-4 py-2.5 text-[14px] outline-none transition-all" placeholder="Tìm theo mã, tên...">
            </div>
            <a asp-action="Index" class="bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 transition-colors ml-auto shadow-sm">
                <i data-lucide="refresh-cw" class="w-4 h-4"></i> Làm mới
            </a>
        </form>
    </div>

    @* --- BẢNG DỮ LIỆU --- *@
    <div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-left text-[14px]">
            <thead class="border-b border-gray-200 bg-gray-50/50">
                <tr>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Mã tài khoản</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Tên tài khoản</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-center">Cấp tài khoản</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-center">Tài khoản cha</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800">Trạng thái</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-right">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        int level = GetAccountLevel(item);
                        string statusBadge = item.Status == AccountStatus.Active ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600";
                        string statusText = item.Status == AccountStatus.Active ? "Hoạt động" : "Ngừng dùng";

                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-5 text-gray-900 font-medium">@item.AccountNumber</td>
                            <td class="py-4 px-5 text-gray-700">
                                <span style="padding-left: @((level - 1) * 20)px">
                                    @item.AccountName
                                </span>
                            </td>
                            <td class="py-4 px-5 text-center text-gray-600">@level</td>
                            <td class="py-4 px-5 text-center text-gray-500">@(item.ParentAccount?.AccountNumber ?? "-")</td>
                            <td class="py-4 px-5">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[12px] font-medium @statusBadge">
                                    @statusText
                                </span>
                            </td>
                            <td class="py-4 px-5 text-right flex items-center justify-end gap-3 text-gray-400">
                                <a asp-action="Details" asp-route-id="@item.Id" class="hover:text-gray-900"><i data-lucide="eye" class="w-4 h-4"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="hover:text-gray-900"><i data-lucide="edit-2" class="w-4 h-4"></i></a>
                                <button class="toggle-status" data-id="@item.Id">
                                    <i data-lucide="@(item.Status == AccountStatus.Active ? "toggle-right" : "toggle-left")" 
                                    class="w-5 h-5 @(item.Status == AccountStatus.Active ? "text-green-500" : "text-gray-300")"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-10 text-center text-gray-500">
                            Không tìm thấy tài khoản nào phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- KHU VỰC PHÂN TRANG (PAGINATION) -->
    @if (totalPages > 1)
    {
        <div class="mt-4 flex items-center justify-between bg-white px-4 py-3 border border-gray-200 rounded-xl shadow-sm">
            <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm text-gray-700">
                        Trang <span class="font-medium">@currentPage</span> / <span class="font-medium">@totalPages</span>
                    </p>
                </div>
                <div>
                    <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                        <!-- Nút Previous -->
                        <a asp-action="Index" 
                           asp-route-pageNumber="@(currentPage - 1)" 
                           asp-route-searchString="@currentSearch" 
                           class="relative inline-flex items-center rounded-l-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 @(currentPage == 1 ? "pointer-events-none opacity-50 bg-gray-100" : "cursor-pointer")">
                            <span class="sr-only">Previous</span>
                            <i data-lucide="chevron-left" class="h-4 w-4"></i>
                        </a>
                        
                        <!-- Hiển thị các số trang -->
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a asp-action="Index" 
                               asp-route-pageNumber="@i" 
                               asp-route-searchString="@currentSearch" 
                               class="relative inline-flex items-center px-4 py-2 text-sm font-semibold @(i == currentPage ? "z-10 bg-[#0f172a] text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0f172a]" : "text-gray-900 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 cursor-pointer")">
                                @i
                            </a>
                        }

                        <!-- Nút Next -->
                        <a asp-action="Index" 
                           asp-route-pageNumber="@(currentPage + 1)" 
                           asp-route-searchString="@currentSearch" 
                           class="relative inline-flex items-center rounded-r-md px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-20 focus:outline-offset-0 @(currentPage == totalPages ? "pointer-events-none opacity-50 bg-gray-100" : "cursor-pointer")">
                            <span class="sr-only">Next</span>
                            <i data-lucide="chevron-right" class="h-4 w-4"></i>
                        </a>
                    </nav>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
        
        // Thêm các JS xử lý toggle trạng thái tài khoản của bạn tại đây (nếu có)
    </script>
}