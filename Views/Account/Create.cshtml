@using RevenueAccountingMVC.Models
@model Account
@{ ViewData["Title"] = "Thêm mới tài khoản"; }

<div class="p-8">
    <div class="flex flex-col gap-4 mb-6">
        @* Nút Quay lại nằm trên *@
        <div>
            <a asp-action="Index" class="inline-flex items-center gap-2 text-[14px] font-medium text-gray-500 hover:text-black transition-colors group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i> 
                Quay lại
            </a>
        </div>

        @* Tiêu đề nằm dưới *@
        <div>
            <h2 class="text-[24px] font-bold text-gray-900">Thêm mới tài khoản</h2>
        </div>
    </div>

    <div class="bg-white border border-gray-100 rounded-xl shadow-sm p-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <div>
                    <label asp-for="AccountNumber" class="block text-[14px] font-medium text-gray-700 mb-1.5">Mã tài khoản <span class="text-red-500">*</span></label>
                    <input asp-for="AccountNumber" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none" placeholder="VD: 511, 111..." />
                    <span asp-validation-for="AccountNumber" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div>
                    <label asp-for="AccountName" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tên tài khoản <span class="text-red-500">*</span></label>
                    <input asp-for="AccountName" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none" placeholder="VD: Doanh thu bán hàng" />
                    <span asp-validation-for="AccountName" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div>
                    <label asp-for="Category" class="block text-[14px] font-medium text-gray-700 mb-1.5">Loại tài khoản <span class="text-red-500">*</span></label>
                    <select asp-for="Category" asp-items="Html.GetEnumSelectList<AccountCategory>()" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none">
                        <option value="">-- Chọn phân loại --</option>
                    </select>
                    <span asp-validation-for="Category" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Nature" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tính chất tài khoản <span class="text-red-500">*</span></label>
                    <select asp-for="Nature" asp-items="Html.GetEnumSelectList<AccountNature>()" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none">
                        <option value="">-- Chọn tính chất --</option>
                    </select>
                    <span asp-validation-for="Nature" class="text-red-500 text-[12px] mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="ParentAccountId" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tài khoản cha (Nếu có)</label>
                    <select asp-for="ParentAccountId" asp-items="ViewBag.ParentAccounts" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none">
                        <option value="">-- Không có tài khoản mẹ (Cấp 1) --</option>
                    </select>
                </div>
                
                <div class="md:col-span-2 flex items-center mt-2 mb-2">
                    <input asp-for="IsDetail" type="checkbox" class="w-4 h-4 text-black bg-gray-50 border-gray-300 rounded focus:ring-black cursor-pointer" />
                    <label asp-for="IsDetail" class="ml-2 text-[14px] font-medium text-gray-800 cursor-pointer">
                        Là tài khoản chi tiết (Được phép hạch toán trực tiếp)
                    </label>
                </div>

                <div>
                    <label asp-for="Status" class="block text-[14px] font-medium text-gray-700 mb-1.5">Trạng thái <span class="text-red-500">*</span></label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<AccountStatus>()" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none"></select>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Description" class="block text-[14px] font-medium text-gray-700 mb-1.5">Mô tả chi tiết</label>
                    <textarea asp-for="Description" rows="2" class="w-full bg-gray-50 border border-gray-300 focus:border-black rounded-lg px-4 py-2.5 text-[14px] outline-none resize-none"></textarea>
                </div>
            </div>

            <div class="mt-8 border-t border-gray-100 pt-5 flex justify-end gap-3">
                <a asp-action="Index" class="px-5 py-2.5 text-[14px] font-semibold text-gray-600 hover:bg-gray-100 rounded-lg">Huỷ bỏ</a>
                <button type="submit" name="submitAction" value="Save" class="bg-gray-100 hover:bg-gray-200 text-black px-6 py-2.5 rounded-lg text-[14px] font-bold"><i data-lucide="save" class="w-4 h-4 inline"></i> Lưu</button>
                <button type="submit" name="submitAction" value="SaveAndNew" class="bg-black hover:bg-gray-800 text-white px-7 py-2.5 rounded-lg text-[14px] font-bold"><i data-lucide="plus-circle" class="w-4 h-4 inline"></i> Lưu & Thêm mới</button>
            </div>
        </form>
    </div>
</div>