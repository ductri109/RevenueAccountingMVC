@using RevenueAccountingMVC.Models
@model IEnumerable<Tax>

@{
    ViewData["Title"] = "Quản lý danh mục thuế";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["ActiveTab"] = "Tax";
    ViewData["CurrentCount"] = Model?.Count() ?? 0;
}

<div class="p-8">
    <div>
        <h2 class="text-[22px] font-bold text-gray-900">Quản lý danh mục</h2>
        <p class="text-[14px] text-gray-500 mt-1">Quản lý dữ liệu danh mục hệ thống</p>
    </div>

    <partial name="_CategoryTabs" />

    <div class="mt-6 bg-white border border-gray-200 rounded-xl p-3 flex items-center gap-3 shadow-sm">
        <a asp-controller="Tax" asp-action="Create" class="bg-[#0f172a] hover:bg-gray-800 text-white px-4 py-2.5 rounded-lg text-[14px] font-medium inline-flex items-center gap-2 transition-colors shadow-sm active:scale-95">
            <i data-lucide="plus" class="w-4 h-4"></i> Thêm mới
        </a>

        <form asp-controller="Tax" asp-action="Index" method="get" class="flex items-center gap-3 flex-1">
            <div class="relative w-[360px]">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
                </div>
                <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="w-full bg-gray-50 border border-transparent focus:bg-white focus:border-gray-300 rounded-lg pl-9 pr-4 py-2.5 text-[14px] text-gray-900 placeholder-gray-400 outline-none transition-all" placeholder="Tìm theo mã, tên thuế...">
            </div>
            <button type="submit" class="hidden"></button>

            <a asp-action="Index" class="bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 transition-colors ml-auto cursor-pointer shadow-sm">
                <i data-lucide="refresh-cw" class="w-4 h-4 text-gray-600"></i> Làm mới
            </a>
        </form>
    </div>

    <div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-left text-[14px]">
            <thead class="border-b border-gray-200 bg-white">
                <tr>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 w-[10%]">Mã thuế</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 w-[25%]">Tên thuế</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 w-[15%]">Thuế suất</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 w-[20%]">Tài khoản hạch toán</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 w-[15%]">Trạng thái</th>
                    <th class="py-3.5 px-5 font-semibold text-gray-800 text-right w-[15%]">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        string statusBadgeClass = item.Status == TaxStatus.Active ? "bg-[#ecfdf5] text-[#059669]" : "bg-gray-100 text-gray-600";
                        string statusName = item.Status == TaxStatus.Active ? "Hoạt động" : "Ngừng áp dụng";
                        bool isToggleOn = item.Status == TaxStatus.Active;

                        <tr class="hover:bg-gray-50/50 transition-colors">
                            <td class="py-4 px-5 font-medium text-gray-900">@item.TaxCode</td>
                            <td class="py-4 px-5 text-gray-700 font-medium">
                                @item.TaxName
                                @if(item.IsDeductible) { <span class="ml-2 text-[10px] bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">Khấu trừ</span> }
                            </td>
                            <td class="py-4 px-5 text-gray-600 font-semibold text-orange-600">@item.TaxRate.ToString("0.##")%</td>
                            <td class="py-4 px-5 text-gray-600">TK: @(item.TaxAccount?.AccountNumber ?? "N/A")</td>
                            <td class="py-4 px-5">
                                <span class="status-badge inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-medium @statusBadgeClass">@statusName</span>
                            </td>
                            <td class="py-4 px-5 flex items-center justify-end gap-3 text-gray-400">
                                <a asp-action="Details" asp-route-id="@item.Id" class="hover:text-blue-600 transition-colors" title="Xem chi tiết">
                                    <i data-lucide="eye" class="w-4 h-4"></i>
                                </a>                                
                                <a asp-action="Edit" asp-route-id="@item.Id" class="hover:text-blue-600 transition-colors" title="Chỉnh sửa">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </a> 
                                <button class="toggle-btn w-8 h-[18px] rounded-full relative transition-colors focus:outline-none border @(isToggleOn ? "bg-[#22c55e] border-transparent" : "bg-gray-200 border-gray-300")" 
                                        data-id="@item.Id">
                                    <div class="toggle-circle w-3.5 h-3.5 bg-white rounded-full absolute shadow-sm @(isToggleOn ? "top-[1px] left-[1px] translate-x-[12px] border-none" : "top-[0px] left-[1px] translate-x-[0px] border border-gray-300")"></div>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-12 px-5 text-center text-gray-500">
                            <i data-lucide="file-text" class="w-12 h-12 mb-3 text-gray-300 mx-auto"></i>
                            <p class="text-[15px] font-medium text-gray-900 mb-1">Không tìm thấy loại thuế</p>
                            <p class="text-[14px]">Hiện tại chưa có dữ liệu trong hệ thống.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') lucide.createIcons();

        // Toggle AJAX
        const toggleBtns = document.querySelectorAll('.toggle-btn');
        toggleBtns.forEach(btn => {
            btn.addEventListener('click', async function() {
                const row = this.closest('tr');
                const statusBadge = row.querySelector('.status-badge');
                const circle = this.querySelector('.toggle-circle');
                const taxId = this.getAttribute('data-id');
                const isCurrentlyActive = this.classList.contains('bg-[#22c55e]');

                try {
                    const response = await fetch(`/Tax/ToggleStatus/${taxId}`, { method: 'POST' });
                    const result = await response.json();

                    if(result.success) {
                        if (isCurrentlyActive) {
                            this.classList.remove('bg-[#22c55e]', 'border-transparent');
                            this.classList.add('bg-gray-200', 'border', 'border-gray-300');
                            circle.style.transform = 'translateX(0px)';
                            circle.classList.add('border', 'border-gray-300');
                            circle.style.top = '0px';

                            statusBadge.textContent = 'Ngừng áp dụng';
                            statusBadge.className = 'status-badge inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-medium bg-gray-100 text-gray-600';
                        } else {
                            this.classList.remove('bg-gray-200', 'border', 'border-gray-300');
                            this.classList.add('bg-[#22c55e]', 'border-transparent');
                            circle.style.transform = 'translateX(12px)';
                            circle.classList.remove('border', 'border-gray-300');
                            circle.style.top = '1px';

                            statusBadge.textContent = 'Hoạt động';
                            statusBadge.className = 'status-badge inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-medium bg-[#ecfdf5] text-[#059669]';
                        }
                    } else alert('Lỗi: ' + result.message);
                } catch (error) { alert('Không thể kết nối máy chủ!'); }
            });
        });
    </script>
}