@using RevenueAccountingMVC.Models
@model Tax

@{
    ViewData["Title"] = "Chi tiết loại thuế";

    // Xử lý text hiển thị
    string statusDisplay = Model.Status == TaxStatus.Active ? "Hoạt động" : "Ngừng áp dụng";
    string isDeductibleDisplay = Model.IsDeductible ? "Có khấu trừ" : "Không khấu trừ";
}

<div class="p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-[22px] font-bold text-gray-900">Xem chi tiết loại thuế</h2>
            <p class="text-[14px] text-gray-500 mt-1">Thông tin tham số của @Model.TaxCode (@Model.TaxName)</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="bg-black hover:bg-gray-800 text-white px-5 py-2.5 rounded-lg text-[14px] font-bold flex items-center gap-2 transition-all shadow-md active:scale-95">
                <i data-lucide="pencil" class="w-4 h-4"></i> Chỉnh sửa
            </a>
            <a asp-action="Index" class="bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 transition-colors shadow-sm">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="bg-white border border-gray-100 rounded-xl shadow-sm p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6 border-transparent">
            
            @* Mã thuế *@
            <div>
                <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Mã thuế</label>
                <input type="text" readonly value="@Model.TaxCode" 
                       class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none font-bold" />
            </div>

            @* Tên thuế *@
            <div>
                <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Tên loại thuế</label>
                <input type="text" readonly value="@Model.TaxName" 
                       class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none font-semibold" />
            </div>

            @* Tên thứ 2 *@
            <div>
                <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Tên thứ 2</label>
                <input type="text" readonly value="@(string.IsNullOrEmpty(Model.SecondaryName) ? "Không có" : Model.SecondaryName)" 
                       class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none" />
            </div>

            @* Thuế suất và Khấu trừ *@
            <div class="flex gap-4 items-end">
                <div class="flex-1">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Thuế suất (%)</label>
                    <input type="text" readonly value="@Model.TaxRate.ToString("0.##")%" 
                           class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-orange-700 cursor-not-allowed outline-none font-bold" />
                </div>
                <div class="flex-1">
                    <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Tính khấu trừ</label>
                    <input type="text" readonly value="@isDeductibleDisplay" 
                           class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none" />
                </div>
            </div>

            @* Tài khoản thuế *@
            <div>
                <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Tài khoản hạch toán</label>
                <input type="text" readonly value="TK: @(Model.TaxAccount != null ? Model.TaxAccount.AccountNumber : "N/A")" 
                       class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none font-medium" />
            </div>

            @* Hàng thời gian và trạng thái *@
            <div class="md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <div>
                    <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Trạng thái sử dụng</label>
                    <input type="text" readonly value="@statusDisplay" 
                           class="w-full bg-[#fef9c3] border border-transparent rounded-lg px-4 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none" />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Ngày tạo</label>
                        <div class="relative">
                            <input type="text" readonly value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")" 
                                   class="w-full bg-[#fef9c3] border border-transparent rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none font-medium" />
                            <i data-lucide="calendar" class="absolute right-3 top-3.5 w-4 h-4 text-gray-500 pointer-events-none inline-block"></i>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[13px] font-semibold text-gray-700 mb-1.5">Cập nhật gần nhất</label>
                        <div class="relative">
                            <input type="text" readonly value="@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có cập nhật")" 
                                   class="w-full bg-[#fef9c3] border border-transparent rounded-lg pl-4 pr-10 py-2.5 text-[14px] text-gray-800 cursor-not-allowed outline-none font-medium" />
                            <i data-lucide="history" class="absolute right-3 top-3.5 w-4 h-4 text-gray-500 pointer-events-none inline-block"></i>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-8 pt-5 border-t border-gray-100 flex justify-end gap-3">
             <a asp-action="Index" class="bg-white border border-gray-300 hover:bg-gray-50 text-black px-6 py-2 rounded-lg text-[13px] font-bold transition-all shadow-sm active:scale-95">
                Đóng
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
}