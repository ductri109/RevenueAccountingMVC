@using RevenueAccountingMVC.Models
@model Tax
@{ ViewData["Title"] = "Thêm mới thuế"; }

<div class="p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-[22px] font-bold text-gray-900">Thêm mới loại thuế</h2>
            <p class="text-[14px] text-gray-500 mt-1">Thiết lập tham số thuế cho hệ thống</p>
        </div>
        <a asp-action="Index" class="bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 px-4 py-2.5 rounded-lg text-[14px] font-medium flex items-center gap-2 shadow-sm">
            <i data-lucide="arrow-left" class="w-4 h-4"></i> Quay lại
        </a>
    </div>

    <div class="bg-white border border-gray-100 rounded-xl shadow-sm p-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                <div>
                    <label asp-for="TaxCode" class="block text-[14px] font-medium text-gray-700 mb-1.5">Mã thuế</label>
                    <input asp-for="TaxCode" type="text" readonly value="@ViewBag.NextTaxCode" class="w-full bg-[#fef9c3] border border-gray-200 rounded-lg px-4 py-2.5 text-[14px] text-gray-800 font-bold outline-none cursor-not-allowed" />
                    <span asp-validation-for="TaxCode" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div>
                    <label asp-for="TaxName" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tên thuế <span class="text-red-500">*</span></label>
                    <input asp-for="TaxName" class="w-full bg-gray-50 border border-gray-300 focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] outline-none" placeholder="VD: Thuế GTGT" />
                    <span asp-validation-for="TaxName" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div>
                    <label asp-for="SecondaryName" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tên thứ 2 (Không bắt buộc)</label>
                    <input asp-for="SecondaryName" class="w-full bg-gray-50 border border-gray-300 focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] outline-none" placeholder="VD: VAT" />
                    <span asp-validation-for="SecondaryName" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div class="flex gap-4 items-start">
                    <div class="flex-1">
                        <label asp-for="TaxRate" class="block text-[14px] font-medium text-gray-700 mb-1.5">Thuế suất (%) <span class="text-red-500">*</span></label>
                        <input asp-for="TaxRate" type="number" step="0.01" class="w-full bg-gray-50 border border-gray-300 focus:border-black focus:ring-1 focus:ring-black rounded-lg px-4 py-2.5 text-[14px] outline-none" placeholder="10" />
                        <span asp-validation-for="TaxRate" class="text-red-500 text-[12px] block mt-1"></span>
                    </div>
                    <div class="mt-9 flex items-center gap-2 px-2">
                        <input asp-for="IsDeductible" type="checkbox" class="w-4 h-4 text-black border-gray-300 rounded focus:ring-black cursor-pointer">
                        <label asp-for="IsDeductible" class="text-[14px] font-medium text-gray-700 cursor-pointer">Tính khấu trừ</label>
                    </div>
                </div>

                <div>
                    <label asp-for="TaxAccountId" class="block text-[14px] font-medium text-gray-700 mb-1.5">Tài khoản hạch toán <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <select asp-for="TaxAccountId" asp-items="ViewBag.Accounts" class="appearance-none w-full bg-gray-50 border border-gray-300 focus:border-black focus:ring-1 focus:ring-black rounded-lg pl-4 pr-10 py-2.5 text-[14px] outline-none cursor-pointer transition-all">
                            <option value="">-- Chọn tài khoản --</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                            <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                        </div>
                    </div>
                    <span asp-validation-for="TaxAccountId" class="text-red-500 text-[12px] block mt-1"></span>
                </div>

                <div>
                    <label asp-for="Status" class="block text-[14px] font-medium text-gray-700 mb-1.5">Trạng thái <span class="text-red-500">*</span></label>
                    <div class="relative">
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<TaxStatus>()" class="appearance-none w-full bg-gray-50 border border-gray-300 focus:border-black focus:ring-1 focus:ring-black rounded-lg pl-4 pr-10 py-2.5 text-[14px] outline-none cursor-pointer transition-all"></select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                            <i data-lucide="chevron-down" class="w-4 h-4 text-gray-400"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-8 border-t border-gray-100 pt-5 flex justify-end gap-3">
                <a asp-action="Index" class="px-5 py-2.5 text-[14px] font-semibold text-gray-600 hover:bg-gray-100 rounded-lg transition-colors">Huỷ bỏ</a>
                <button type="submit" name="submitAction" value="Save" class="bg-gray-100 hover:bg-gray-200 text-black px-6 py-2.5 rounded-lg text-[14px] font-bold transition-colors"><i data-lucide="save" class="w-4 h-4 inline"></i> Lưu</button>
                <button type="submit" name="submitAction" value="SaveAndNew" class="bg-black hover:bg-gray-800 text-white px-7 py-2.5 rounded-lg text-[14px] font-bold transition-colors active:scale-95"><i data-lucide="plus-circle" class="w-4 h-4 inline"></i> Lưu & Thêm mới</button>
            </div>
        </form>
    </div>
</div>

@section Scripts { 
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} 
    <script>lucide.createIcons();</script> 
}